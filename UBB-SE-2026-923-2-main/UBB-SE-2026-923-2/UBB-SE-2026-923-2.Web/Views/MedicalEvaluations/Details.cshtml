@model UBB_SE_2026_923_2.Models.MedicalEvaluation
@{
    ViewData["Title"] = "Evaluation Details";
}

<h2>Evaluation Details</h2>

<div class="card p-4 mt-3 col-md-8">
    <h4 class="text-primary">Patient ID: @Model.PatientId</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-4">Evaluation ID</dt>
        <dd class="col-sm-8">@Model.EvaluationID</dd>

        <dt class="col-sm-4">Doctor</dt>
        <dd class="col-sm-8">@Model.Evaluator?.FirstName @Model.Evaluator?.LastName</dd>

        <dt class="col-sm-4">Symptoms / Diagnosis</dt>
        <dd class="col-sm-8">@Model.Symptoms</dd>

        <dt class="col-sm-4">Medications</dt>
        <dd class="col-sm-8 fw-bold text-danger">@Model.MedicationsList</dd>

        <dt class="col-sm-4">Doctor Notes</dt>
        <dd class="col-sm-8">@Model.Notes</dd>
    </dl>
    <div class="mt-3">
        <a asp-action="Edit" asp-route-evaluationId="@Model.EvaluationID" class="btn btn-warning">Edit</a>
        <a asp-action="Index" asp-route-doctorId="@Model.Evaluator?.StaffID" class="btn btn-secondary ms-2">Back to List</a>
    </div>
</div>
@model UBB_SE_2026_923_2.Models.MedicalEvaluation
@{
    ViewData["Title"] = "Delete Evaluation";
}

<h2>Delete Evaluation</h2>

<div class="alert alert-danger mt-3 col-md-8">
    <h4>Warning!</h4>
    <p>Are you sure you want to permanently delete Evaluation #@Model.EvaluationID for Patient @Model.PatientId?</p>
</div>

<div class="card p-4 col-md-8">
    <dl class="row">
        <dt class="col-sm-4">Doctor</dt>
        <dd class="col-sm-8">@Model.Evaluator?.FirstName @Model.Evaluator?.LastName</dd>

        <dt class="col-sm-4">Diagnosis</dt>
        <dd class="col-sm-8">@Model.Symptoms</dd>
    </dl>

    <form asp-action="Delete" asp-route-evaluationId="@Model.EvaluationID" method="post" class="mt-3">
        <button type="submit" class="btn btn-danger">Yes, Delete Record</button>
        <a asp-action="Index" asp-route-doctorId="@Model.Evaluator?.StaffID" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>
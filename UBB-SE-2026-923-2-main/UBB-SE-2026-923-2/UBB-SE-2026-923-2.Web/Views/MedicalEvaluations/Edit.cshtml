@model UBB_SE_2026_923_2.Models.MedicalEvaluation
@{
    ViewData["Title"] = "Edit Evaluation";
}

<h2>Edit Evaluation #@Model.EvaluationID</h2>

<div class="card p-4 mt-3 col-md-8">
    <form asp-action="Edit" method="post">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="EvaluationID" />
        <input type="hidden" asp-for="PatientId" />

        <div class="form-group mb-3">
            <label class="control-label fw-bold text-muted">Active Patient ID (Read-Only)</label>
            <input class="form-control bg-light" value="@Model.PatientId" readonly />
        </div>

        <div class="form-group mb-3">
            <label class="control-label fw-bold">Symptoms</label>
            <textarea asp-for="Symptoms" class="form-control" rows="4" placeholder="Enter symptoms..." maxlength="500"></textarea>
        </div>

        <div class="form-group mb-3">
            <label class="control-label fw-bold">Meds List</label>
            <textarea asp-for="MedicationsList" class="form-control" rows="2" placeholder="Enter medications..." maxlength="200"></textarea>
        </div>

        <div class="form-check mb-3">
            <input class="form-check-input" type="checkbox" value="true" name="IsRiskAssumed" id="riskCheckEdit">
            <label class="form-check-label fw-bold text-danger" for="riskCheckEdit">
                I assume clinical risk for this prescription
            </label>
        </div>

        <div class="form-group mb-4">
            <label class="control-label fw-bold">Doctor Notes</label>
            <textarea asp-for="Notes" class="form-control" rows="4" placeholder="Write justification here..." maxlength="1000"></textarea>
        </div>

        <button type="submit" class="btn btn-primary w-100 mb-2">Save Diagnosis</button>

        <a asp-action="Delete" asp-route-evaluationId="@Model.EvaluationID" class="btn btn-danger w-100 mb-2">Delete Diagnosis</a>
        <a asp-action="Index" asp-route-doctorId="@Model.Evaluator?.StaffID" class="btn btn-outline-primary w-100">Cancel Selection</a>
    </form>
</div>
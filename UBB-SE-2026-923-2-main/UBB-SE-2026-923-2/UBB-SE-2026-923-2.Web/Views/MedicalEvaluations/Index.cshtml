@model IEnumerable<UBB_SE_2026_923_2.Models.MedicalEvaluation>
@{
    ViewData["Title"] = "Medical Evaluations";
    var doctorList = ViewBag.DoctorList as IEnumerable<UBB_SE_2026_923_2.Models.Doctor>;
}

<h2>Medical Evaluations</h2>

@if (ViewData["WarningMessage"] != null)
{
    <div class="alert alert-danger text-center p-4 mb-4">
        <h3 class="fw-bold text-danger mb-2">CLINICAL LOCKOUT.</h3>
        <p class="mb-0 fs-5">Maximum duty hours (12h) exceeded. @ViewData["WarningMessage"]</p>
    </div>
}

<div class="card p-3 mb-4 bg-light">
    <form asp-action="Index" method="get" class="d-flex align-items-center flex-wrap gap-3">
        <div class="d-flex align-items-center">
            <label class="me-2 fw-bold text-muted">Current Staff:</label>
            <select name="doctorId" class="form-select" style="width: 250px;" onchange="this.form.submit()">
                <option value="">-- Choose Doctor --</option>
                @if (doctorList != null)
                {
                    foreach (var doctor in doctorList)
                    {
                        bool isSelected = ViewBag.SelectedDoctorId == doctor.StaffID.ToString();
                        <option value="@doctor.StaffID" selected="@isSelected">Dr. @doctor.FirstName @doctor.LastName - ID: @doctor.StaffID</option>
                    }
                }
            </select>
        </div>

        <div class="d-flex align-items-center">
            <label class="me-2 fw-bold text-muted">Filter History:</label>
            <input type="text" name="searchPatientId" class="form-control" placeholder="Search by Patient ID..." value="@ViewBag.SearchText" style="width: 250px;">
            <button type="submit" class="btn btn-secondary ms-2">Search</button>
        </div>

        <a asp-action="Create" class="btn btn-primary ms-auto">New Evaluation</a>
    </form>
</div>

@if (Model != null && Model.Any())
{
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Date / Time</th>
                <th>Symptoms</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <strong>@item.EvaluationDate.ToString("dd MMM yyyy")</strong><br />
                        <span class="text-muted small">@item.EvaluationDate.ToString("HH:mm")</span>
                    </td>
                    <td>
                        <div class="text-truncate" style="max-width: 250px;">@item.Symptoms</div>
                    </td>
                    <td><span class="text-success fw-bold">Completed</span></td>
                    <td>
                        <a asp-action="Details" asp-route-evaluationId="@item.EvaluationID" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Edit" asp-route-evaluationId="@item.EvaluationID" class="btn btn-sm btn-warning">Edit</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else if (!string.IsNullOrEmpty(ViewBag.SelectedDoctorId))
{
    <div class="text-center mt-5">
        <i class="bi bi-journal-x fs-1 text-muted opacity-50"></i>
        <p class="text-muted fst-italic mt-2">No records found.</p>
    </div>
}
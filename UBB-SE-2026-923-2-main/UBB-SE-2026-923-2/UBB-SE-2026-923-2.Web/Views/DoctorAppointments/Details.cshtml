@model UBB_SE_2026_923_2.Web.ViewModels.DoctorAppointmentDetailsViewModel
@{
    ViewData["Title"] = "Appointment Details";
    var successMessage = TempData["DetailsSuccess"] as string;
    var errorMessage = TempData["DetailsError"] as string;
    var isFinished = string.Equals(Model.Status, "Finished", StringComparison.OrdinalIgnoreCase);
}

<div class="d-flex justify-content-center">
    <div class="card shadow-sm border-primary" style="max-width: 480px; width: 100%;">
        <div class="card-body p-4">
            <h3 class="text-primary fw-semibold mb-4">Appointment Details</h3>

            <div class="mb-3">
                <div class="text-muted small">Patient:</div>
                <div class="fs-5 fw-bold">@Model.PatientName</div>
            </div>

            <div class="mb-3">
                <div class="text-muted small">Doctor:</div>
                <div class="fs-5">@Model.DoctorName</div>
            </div>

            <div class="row mb-4">
                <div class="col-6">
                    <div class="text-muted small">Date:</div>
                    <div>@Model.Date.ToString("yyyy-MM-dd")</div>
                </div>
                <div class="col-6">
                    <div class="text-muted small">Time:</div>
                    <div>@Model.StartTime.ToString(@"hh\:mm") - @Model.EndTime.ToString(@"hh\:mm")</div>
                </div>
            </div>

            <div class="mb-4">
                <div class="text-muted small">Current Status:</div>
                <div class="fs-5 fw-semibold text-primary">@Model.Status</div>
            </div>

            <form asp-action="Finish" asp-route-id="@Model.Id" method="post">
                <button type="submit" class="btn btn-primary w-100 mb-2" @(isFinished ? "disabled" : "")>
                    Mark as Finished
                </button>
            </form>

            <a asp-controller="DoctorSchedule" asp-action="Index"
               class="btn btn-outline-primary w-100">Go Back</a>

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success mt-3 mb-0">@successMessage</div>
            }
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-3 mb-0">@errorMessage</div>
            }
        </div>
    </div>
</div>

@model UBB_SE_2026_923_2.Web.ViewModels.DoctorAppointmentDeleteViewModel
@{
    ViewData["Title"] = "Cancel appointment";
}

<h2 class="mb-3">Cancel appointment</h2>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<dl class="row">
    <dt class="col-sm-3">Doctor</dt>
    <dd class="col-sm-9">@Model.DoctorName</dd>

    <dt class="col-sm-3">Patient</dt>
    <dd class="col-sm-9">@Model.PatientName</dd>

    <dt class="col-sm-3">Date</dt>
    <dd class="col-sm-9">@Model.Date.ToString("yyyy-MM-dd")</dd>

    <dt class="col-sm-3">Time</dt>
    <dd class="col-sm-9">@Model.StartTime.ToString(@"hh\:mm") - @Model.EndTime.ToString(@"hh\:mm")</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>
</dl>

<form asp-action="Delete" method="post" class="d-flex gap-2">
    <input asp-for="Id" type="hidden" />
    <button type="submit" class="btn btn-danger">Confirm cancel</button>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Back</a>
</form>

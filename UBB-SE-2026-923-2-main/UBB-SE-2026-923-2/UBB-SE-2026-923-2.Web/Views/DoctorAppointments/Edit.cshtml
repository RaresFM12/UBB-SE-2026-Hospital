@using System
@model UBB_SE_2026_923_2.Web.ViewModels.DoctorAppointmentEditViewModel
@{
    ViewData["Title"] = "Update appointment";
}

<h2 class="mb-3">Update appointment status</h2>

<form asp-action="Edit" method="post" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <input asp-for="Id" type="hidden" />

    <div class="col-md-6">
        <label class="form-label">Doctor</label>
        <input class="form-control" value="@Model.DoctorName" readonly />
    </div>

    <div class="col-md-6">
        <label class="form-label">Patient</label>
        <input class="form-control" value="@Model.PatientName" readonly />
    </div>

    <div class="col-md-4">
        <label class="form-label">Date</label>
        <input class="form-control" value="@Model.Date.ToString("yyyy-MM-dd")" readonly />
    </div>

    <div class="col-md-4">
        <label class="form-label">Start</label>
        <input class="form-control" value="@Model.StartTime.ToString(@"hh\:mm")" readonly />
    </div>

    <div class="col-md-4">
        <label class="form-label">End</label>
        <input class="form-control" value="@Model.EndTime.ToString(@"hh\:mm")" readonly />
    </div>

    <div class="col-md-6">
        <label asp-for="Status" class="form-label"></label>
        <select asp-for="Status" class="form-select">
            @foreach (var option in Model.StatusOptions)
            {
                <option value="@option" selected="@(string.Equals(option, Model.Status, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@option</option>
            }
        </select>
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>

    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

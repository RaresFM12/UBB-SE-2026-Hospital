@model UBB_SE_2026_923_2.Web.ViewModels.IncomingSwapRequestsViewModel
@using UBB_SE_2026_923_2.Models

@{
    ViewData["Title"] = "Incoming Swap Requests";
}

<div class="row mt-1">
    <div class="col-md-6">
        <div class="card border-primary shadow-sm">
            <div class="card-body">
                <h4 class="card-title text-primary fw-semibold mb-3">Incoming Swap Requests</h4>

                <form asp-action="Incoming" method="get" class="mb-3">
                    <label class="form-label text-muted">Select doctor (test mode)</label>
                    <select name="selectedDoctorId" class="form-select" onchange="this.form.submit()">
                        <option value="">Select doctor</option>
                        @foreach (var doctor in Model.Doctors)
                        {
                            if (Model.SelectedDoctorId == doctor.StaffID)
                            {
                                <option value="@doctor.StaffID" selected>@doctor.FirstName @doctor.LastName</option>
                            }
                            else
                            {
                                <option value="@doctor.StaffID">@doctor.FirstName @doctor.LastName</option>
                            }
                        }
                    </select>
                </form>

                @if (!string.IsNullOrEmpty(Model.StatusMessage))
                {
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-1"></i> @Model.StatusMessage
                    </div>
                }

                <form method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="selectedDoctorId" value="@Model.SelectedDoctorId" />

                    <div class="list-group mb-3" style="min-height: 260px;">
                        @if (!Model.Requests.Any())
                        {
                            <div class="text-muted p-3">No pending requests.</div>
                        }
                        else
                        {
                            var requestIndex = 0;
                            foreach (var request in Model.Requests)
                            {
                                <label class="list-group-item border border-primary rounded mb-2 list-group-item-action cursor-pointer">
                                    <div class="d-flex align-items-center">
                                        <input class="form-check-input me-3" type="radio" name="swapId" value="@request.SwapId" checked="@(requestIndex == 0)" required>
                                        <div>
                                            <strong>From:</strong> @request.Requester?.FirstName @request.Requester?.LastName<br />
                                            <strong>Shift:</strong> @request.Shift?.StartTime.ToString("dd MMM yyyy HH:mm") - @request.Shift?.EndTime.ToString("HH:mm")<br />
                                            <strong>Location:</strong> @request.Shift?.Location<br />
                                            <strong>Requested:</strong> @request.RequestedAt.ToString("dd MMM yyyy HH:mm")
                                        </div>
                                    </div>
                                </label>
                                requestIndex++;
                            }
                        }
                    </div>

                    <div class="d-flex gap-2">
                        <a asp-action="Incoming" asp-route-selectedDoctorId="@Model.SelectedDoctorId" class="btn btn-outline-primary">Refresh</a>
                        <button type="submit" asp-action="Accept" class="btn btn-primary" disabled="@(!Model.Requests.Any())">Accept</button>
                        <button type="submit" asp-action="Reject" class="btn btn-danger" disabled="@(!Model.Requests.Any())">Reject</button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>
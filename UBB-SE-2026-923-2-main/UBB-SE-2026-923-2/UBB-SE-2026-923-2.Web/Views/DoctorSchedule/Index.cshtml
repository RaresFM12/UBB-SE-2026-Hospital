@model UBB_SE_2026_923_2.Web.ViewModels.DoctorScheduleViewModel
@using UBB_SE_2026_923_2.Models

@{
    ViewData["Title"] = "Doctor Schedule";
    var doctors = ViewBag.Doctors as List<Doctor> ?? new List<Doctor>();
    var selectedDoctorId = ViewBag.SelectedDoctorId as int?;
    var mode = ViewBag.Mode as string ?? "Daily";
    var selectedDate = ViewBag.SelectedDate as string ?? DateTime.Today.ToString("yyyy-MM-dd");
    var selectedDateText = ViewBag.SelectedDateText as string ?? DateTime.Today.ToString("dddd, dd MMM yyyy");
    var previousButtonText = ViewBag.PreviousButtonText as string ?? "Previous";
    var nextButtonText = ViewBag.NextButtonText as string ?? "Next";
    var isEmpty = ViewBag.IsEmpty as bool? ?? false;
    var errorMessage = ViewBag.ErrorMessage as string;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Doctor Schedule</h2>

    <form asp-action="Index" method="get">
        <input type="hidden" name="selectedDate" value="@selectedDate" />
        <input type="hidden" name="mode" value="@mode" />
        <select name="selectedDoctorId" class="form-select" style="width:320px" onchange="this.form.submit()">
            <option value="">Select doctor</option>
            @foreach (var doctor in doctors)
            {
                <option value="@doctor.StaffID" selected="@(selectedDoctorId == doctor.StaffID ? "selected" : null)">
                    @doctor.FirstName @doctor.LastName
                </option>
            }
        </select>
    </form>
</div>

<div class="d-flex flex-wrap gap-2 align-items-center mb-3">
    <a asp-action="Index"
       asp-route-selectedDoctorId="@selectedDoctorId"
       asp-route-selectedDate="@selectedDate"
       asp-route-mode="@mode"
       asp-route-nav="prev"
       class="btn btn-outline-secondary">@previousButtonText</a>

    <a asp-action="Index"
       asp-route-selectedDoctorId="@selectedDoctorId"
       asp-route-selectedDate="@DateTime.Today.ToString("yyyy-MM-dd")"
       asp-route-mode="@mode"
       asp-route-nav="today"
       class="btn btn-outline-secondary">Today</a>

    <a asp-action="Index"
       asp-route-selectedDoctorId="@selectedDoctorId"
       asp-route-selectedDate="@selectedDate"
       asp-route-mode="@mode"
       asp-route-nav="next"
       class="btn btn-outline-secondary">@nextButtonText</a>

    <form asp-action="Index" method="get" class="position-relative d-inline ms-2">
        <input type="hidden" name="selectedDoctorId" value="@selectedDoctorId" />
        <input type="hidden" name="mode" value="@mode" />
        <input type="date" id="schedDateInput" name="selectedDate" value="@selectedDate"
               onchange="this.form.submit();"
               style="position:absolute; opacity:0; width:1px; height:1px; pointer-events:none; left:0; top:0;" />
        <button type="button" class="btn btn-outline-primary"
                onclick="openSchedDatePicker();">@selectedDateText</button>
    </form>

    <a asp-action="Index"
       asp-route-selectedDoctorId="@selectedDoctorId"
       asp-route-selectedDate="@selectedDate"
       asp-route-mode="Daily"
       class="btn btn-outline-secondary ms-2">Daily</a>

    <a asp-action="Index"
       asp-route-selectedDoctorId="@selectedDoctorId"
       asp-route-selectedDate="@selectedDate"
       asp-route-mode="Weekly"
       class="btn btn-outline-secondary">Weekly</a>

    <a asp-action="Index"
       asp-route-selectedDoctorId="@selectedDoctorId"
       asp-route-selectedDate="@selectedDate"
       asp-route-mode="@mode"
       class="btn btn-outline-secondary">Refresh</a>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="border rounded p-3 mb-3" style="border-color:#dc3545 !important; color:#dc3545;">
        @errorMessage
    </div>
}

@if (isEmpty)
{
    <div class="text-center py-5">
        <p class="fs-5">No appointments or shifts for this period.</p>
        <p class="text-muted">Try Previous/Next, click date, or Refresh.</p>
    </div>
}

<h5 class="text-primary fw-semibold mb-3">Appointments</h5>

<div class="d-flex flex-column gap-3 mb-4">
    @foreach (var appointment in Model.Appointments)
    {
        <div class="card border shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-muted fs-4">@appointment.Date.ToString("dd MMM yyyy")</div>
                    <div class="fw-semibold fs-3">@appointment.StartTime.ToString(@"hh\:mm") - @appointment.EndTime.ToString(@"hh\:mm")</div>
                    <div class="text-muted fs-5">@appointment.Status</div>
                </div>
                <a asp-controller="DoctorAppointments"
                   asp-action="Details"
                   asp-route-id="@appointment.Id"
                   class="btn btn-primary">Details</a>
            </div>
        </div>
    }
</div>

<h5 class="text-primary fw-semibold mb-3">Shifts</h5>

<div class="d-flex flex-column gap-3">
    @foreach (var shift in Model.Shifts)
    {
        <div class="card border shadow-sm">
            <div class="card-body">
                <div class="text-muted fs-4">@shift.StartTime.ToString("dd MMM yyyy")</div>
                <div class="fw-semibold fs-3">@shift.StartTime.ToString("HH:mm") - @shift.EndTime.ToString("HH:mm")</div>
                <div class="text-muted fs-5">@(string.IsNullOrWhiteSpace(shift.Location) ? "Location TBD" : shift.Location)</div>
                <div class="text-muted">@shift.Status</div>
            </div>
        </div>
    }
</div>

<script>
    function openSchedDatePicker() {
        var input = document.getElementById('schedDateInput');
        if (input && typeof input.showPicker === 'function') {
            input.showPicker();
        } else if (input) {
            input.focus();
            input.click();
        }
    }
</script>

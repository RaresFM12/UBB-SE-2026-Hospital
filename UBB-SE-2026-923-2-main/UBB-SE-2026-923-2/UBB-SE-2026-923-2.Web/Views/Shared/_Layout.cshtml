<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hospital</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/UBB_SE_2026_923_2.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">Hospital</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
               
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @* Each feature owner: add a <li> here pointing at your controller.
                               Use @if (User.IsInRole("Admin")) { ... } to gate role-specific entries. *@

                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="UserAccounts" asp-action="Edit">Profile</a>
                            </li>

                            @if (!User.IsInRole("Admin") && !User.IsInRole("Pharmacist") && !User.IsInRole("Doctor"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-controller="ProductCatalogue" asp-action="Index">Product Catalogue</a>
                                </li>
                            }

                            @if (User.IsInRole("Client"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Basket" asp-action="Index">Shopping Cart</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Notifications" asp-action="Index">Notifications</a>
                                </li>
                            }

                            @if (!User.IsInRole("Admin") && !User.IsInRole("Pharmacist") && !User.IsInRole("Doctor"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Orders" asp-action="Index">Order History</a>
                                </li>
                            }

                            @if (User.IsInRole("Client"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-controller="PeriodTracker" asp-action="Index">Period Tracker</a>
                                </li>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Items" asp-action="Index">Inventory</a>
                                </li>
                            }

                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="ShiftManagement" asp-action="Index">Shift Management</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="ERDispatch" asp-action="Index">ER Dispatch</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="FatigueAudit" asp-action="Index">Fatigue Audit</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="UserAccounts" asp-action="Index">Accounts Management</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="DoctorAppointments" asp-action="Index">Appointments</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="DoctorSchedule" asp-action="Index">Doctor Schedule</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="PharmacySchedule" asp-action="Index">Pharmacy Schedule</a>
                                </li>
                            }

                            @if (User.IsInRole("Doctor"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="ShiftSwap" asp-action="Index">Shift Swap Requests</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="ShiftSwap" asp-action="Incoming">Incoming Swap Requests</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="DoctorSchedule" asp-action="Index">My Schedule</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="ShiftManagement" asp-action="Salary">Salary</a>
                                </li>
                            }

                            @if (User.IsInRole("Doctor"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Hangouts" asp-action="Index">Hangouts</a>
                                </li>
                            }
                            
                            @if (User.IsInRole("Pharmacist"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Prescriptions" asp-action="Index">Prescriptions</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="ShiftManagement" asp-action="Salary">Salary</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="" asp-controller="PharmacySchedule" asp-action="Index">See Schedule</a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="PharmacyVacation" asp-action="Index">Vacation Window</a>
                                </li>
                            }

                        }
                    </ul>

                    <ul class="navbar-nav">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="navbar-text me-3">Signed in as <strong>@User.Identity!.Name</strong></span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Login" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-secondary btn-sm">Sign out</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-outline-primary btn-sm me-2" asp-controller="UserAccounts" asp-action="Create">Register</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm" asp-controller="Login" asp-action="Index">Sign in</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Hospital - <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

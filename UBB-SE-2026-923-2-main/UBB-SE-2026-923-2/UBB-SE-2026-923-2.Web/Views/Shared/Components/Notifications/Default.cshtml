@model UBB_SE_2026_923_2.Web.ViewModels.NotificationsDropdownViewModel

<li class="nav-item dropdown">
    <a class="nav-link dropdown-toggle text-dark position-relative me-2" href="#" id="notificationsDropdown"
       role="button" data-bs-toggle="dropdown" aria-expanded="false" title="Notifications"
       style="padding-right: 1rem;">
        &#128276;
        @if (Model.UnreadCount > 0)
        {
            <span class="position-absolute badge rounded-pill bg-danger"
                  style="font-size: 0.6rem; padding: 3px 5px; top: 4px; left: 16px;">
                @Model.UnreadCount
            </span>
        }
    </a>
    <ul class="dropdown-menu dropdown-menu-end shadow p-0"
        style="min-width: 320px; max-height: 420px; overflow-y: auto;"
        aria-labelledby="notificationsDropdown">

        <li class="px-3 py-2 bg-light border-bottom">
            <span class="fw-bold small text-secondary">NOTIFICATIONS</span>
        </li>

        @if (!Model.Notifications.Any())
        {
            <li class="px-3 py-3 text-center">
                <span class="text-muted small">You have no notifications.</span>
            </li>
        }
        else
        {
            foreach (var notification in Model.Notifications)
            {
                <li class="border-bottom">
                    <div class="px-3 py-2">
                        <div class="fw-bold small text-primary">@notification.Title</div>
                        <div class="text-muted small mt-1">@notification.Body</div>
                    </div>
                </li>
            }
        }

        <li>
            <a class="dropdown-item text-center small fw-bold text-primary py-2 border-top"
               asp-controller="Notifications" asp-action="Index">
                View all notifications
            </a>
        </li>
    </ul>
</li>

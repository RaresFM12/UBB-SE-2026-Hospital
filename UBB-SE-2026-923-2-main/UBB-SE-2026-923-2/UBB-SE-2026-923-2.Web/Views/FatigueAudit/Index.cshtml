@model UBB_SE_2026_923_2.Models.AutoAuditResult
@{
    ViewData["Title"] = "Staff Fatigue Audit & Roster Validation";
}

<h2>Staff Fatigue Audit &amp; Roster Validation</h2>

<form method="get" asp-action="Index" class="row mb-4 align-items-end">
    <div class="col-auto">
        <label for="weekStart" class="form-label">Week starting</label>
        <input type="date" id="weekStart" name="weekStart" class="form-control"
               value="@Model.WeekStart.ToString("yyyy-MM-dd")" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Run Auto-Audit</button>
    </div>
    <div class="col-auto">
        <a asp-action="Index" class="btn btn-outline-primary">Refresh</a>
    </div>
</form>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card mb-3">
    <div class="card-body">
        <h6 class="card-subtitle mb-2 text-muted">Audit Status</h6>
        <p class="mb-1">@Model.Summary</p>
        <small class="text-muted">Week of @Model.WeekStart.ToString("dd MMM yyyy")</small>
    </div>
</div>

<div class="alert @(Model.CanPublish ? "alert-success" : "alert-warning")">
    <strong>Publish status: @(Model.CanPublish ? "READY" : "BLOCKED")</strong> &mdash; @Model.Summary
</div>

@if (Model.Violations.Count > 0)
{
    <h4>Fatigue Violations Detected</h4>
    <p class="text-muted">Rules: Max 60h/week, Min 12h rest between shifts</p>
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Shift ID</th>
                <th>Staff</th>
                <th>Start</th>
                <th>End</th>
                <th>Rule</th>
                <th>Message</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var v in Model.Violations)
            {
                <tr>
                    <td>@v.ShiftId</td>
                    <td>@v.StaffName (ID @v.StaffId)</td>
                    <td>@v.ShiftStart.ToString("ddd dd MMM HH:mm")</td>
                    <td>@v.ShiftEnd.ToString("ddd dd MMM HH:mm")</td>
                    <td><span class="badge bg-danger">@v.Rule</span></td>
                    <td>@v.Message</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@v.ShiftId" asp-route-weekStart="@Model.WeekStart.ToString("yyyy-MM-dd")" class="btn btn-sm btn-outline-primary">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@if (Model.Suggestions.Count > 0)
{
    <h4>Auto-Suggested Reassignments</h4>
    <p class="text-muted">System recommends these changes to resolve violations</p>
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Shift ID</th>
                <th>Current Staff</th>
                <th>Suggested Staff</th>
                <th>Reason</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model.Suggestions)
            {
                <tr>
                    <td>@s.ShiftId</td>
                    <td>@s.OriginalStaffName</td>
                    <td>
                        @if (s.SuggestedStaffId.HasValue)
                        {
                            @s.SuggestedStaffName
                        }
                        else
                        {
                            <span class="text-muted">None available</span>
                        }
                    </td>
                    <td>@s.Reason</td>
                    <td>
                        @if (s.SuggestedStaffId.HasValue)
                        {
                            <a asp-action="Reassign" asp-route-shiftId="@s.ShiftId" asp-route-weekStart="@Model.WeekStart.ToString("yyyy-MM-dd")" class="btn btn-sm btn-outline-success">Reassign</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="card mt-4 @(Model.CanPublish ? "border-success" : "border-warning")">
    <div class="card-header">
        <strong>Roster Publication</strong>
    </div>
    <div class="card-body">
        <p class="fw-semibold @(Model.CanPublish ? "text-success" : "text-warning")">
            Publish status: @(Model.CanPublish ? "READY" : "BLOCKED")
        </p>
        <p class="text-muted">
            @if (Model.CanPublish)
            {
                @:No violations detected. Roster is ready to publish.
            }
            else
            {
                @:Roster cannot be published while violations exist. Run audit and resolve all conflicts.
            }
        </p>
        <form asp-action="Publish" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="weekStart" value="@Model.WeekStart.ToString("yyyy-MM-dd")" />
            <button type="submit" class="btn btn-success" @(Model.CanPublish ? "" : "disabled")>Publish Roster</button>
        </form>
    </div>
</div>

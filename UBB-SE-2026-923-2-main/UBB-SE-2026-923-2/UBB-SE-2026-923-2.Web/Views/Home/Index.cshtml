@{
    ViewData["Title"] = "Home";
}

<div class="text-center mt-5">
    <h1 class="display-4">Hospital Management</h1>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <p class="lead">Welcome back, <strong>@User.Identity!.Name</strong>. Use the navigation above to access your features.</p>
    }
    else
    {
        <p class="lead">Please sign in to continue.</p>
        <a asp-controller="Login" asp-action="Index" class="btn btn-primary btn-lg">Sign in</a>
    }
</div>

@model PharmacyVacationViewModel
@{
    ViewData["Title"] = "Vacation Window";
}

<h2 class="mb-4">Vacation Window</h2>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert @Model.StatusCssClass" role="alert">
        @Model.StatusMessage
    </div>
}

<form asp-controller="PharmacyVacation" asp-action="Index" method="post" class="row g-3">
    @Html.AntiForgeryToken()

    <div class="col-md-4">
        <label asp-for="PharmacistStaffId" class="form-label">Pharmacist</label>
        <select asp-for="PharmacistStaffId" asp-items="Model.Pharmacists" class="form-select">
            <option value="">Select pharmacist</option>
        </select>
    </div>

    <div class="col-md-3">
        <label asp-for="StartDate" class="form-label">Start date</label>
        <input asp-for="StartDate" type="date" class="form-control" />
    </div>

    <div class="col-md-3">
        <label asp-for="EndDate" class="form-label">End date</label>
        <input asp-for="EndDate" type="date" class="form-control" />
    </div>

    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-primary w-100">Add Vacation</button>
    </div>
</form>

@model UBB_SE_2026_923_2.Web.ViewModels.UserAccountListViewModel
@{
    ViewData["Title"] = "User Accounts";
}

<div class="mb-3">
    <h2>User Accounts</h2>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-8">
        <input asp-for="Query" class="form-control" placeholder="Search users..." autocomplete="off" />
    </div>
    <div class="col-md-4">
        <button type="submit" class="btn btn-outline-primary">Search</button>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (Model.Users.Count == 0)
{
    <div class="alert alert-info">No user accounts found.</div>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var user in Model.Users)
        {
            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                        <div class="fw-semibold text-primary">@user.Email</div>
                        @if (user.IsDisabled)
                        {
                            <span class="badge bg-secondary">Disabled</span>
                        }
                        @if (user.IsAdmin)
                        {
                            <span class="badge bg-primary">Admin</span>
                        }
                        else if (!user.IsDisabled)
                        {
                            <span class="badge bg-success">Active</span>
                        }
                        <span class="badge bg-light text-dark border">@user.DisplayRole</span>
                    </div>
                    <div class="text-muted small mb-1">@(string.IsNullOrWhiteSpace(user.Username) ? "(no username)" : user.Username)</div>
                    <div class="text-muted small mb-3">@(string.IsNullOrWhiteSpace(user.PhoneNumber) ? "(no phone)" : user.PhoneNumber)</div>

                    <div class="d-flex align-items-center gap-3">
                        @if (user.CanPromote)
                        {
                            <form asp-action="Promote" asp-route-id="@user.Id" method="post" class="d-inline" id="promote-form-@user.Id">
                                @Html.AntiForgeryToken()
                                <div class="form-check d-flex align-items-center gap-2 mb-0">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           id="admin-@user.Id"
                                           onchange="confirmPromote(@user.Id)" />
                                    <label class="form-check-label" for="admin-@user.Id">Admin</label>
                                </div>
                            </form>
                        }
                        else if (user.IsAdmin)
                        {
                            <div class="form-check d-flex align-items-center gap-2 mb-0">
                                <input class="form-check-input" type="checkbox" checked disabled />
                                <label class="form-check-label text-muted">Admin</label>
                            </div>
                        }

                        @if (user.CanDisable)
                        {
                            <form asp-action="Delete" asp-route-id="@user.Id" method="post" class="d-inline" id="disable-form-@user.Id">
                                @Html.AntiForgeryToken()
                                <button type="button"
                                        class="btn btn-primary btn-sm"
                                        onclick="confirmDisable(@user.Id)">
                                    Disable Account
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

<!-- Promote Warning Modal -->
<div class="modal fade" id="promoteModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-body">
                <h5 class="fw-semibold mb-2">Warning</h5>
                <p>This action cannot be undone. Proceed?</p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary" onclick="cancelPromote()">Cancel</button>
                <button type="button" class="btn btn-primary" id="promoteConfirmBtn">Proceed</button>
            </div>
        </div>
    </div>
</div>

<!-- Disable Confirm Modal -->
<div class="modal fade" id="disableModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-body">
                <h5 class="fw-semibold mb-2">Confirm</h5>
                <p>Disable this account?</p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">No</button>
                <button type="button" class="btn btn-primary" id="disableConfirmBtn">Yes</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var currentPromoteId = null;
        var currentDisableId = null;
        var promoteModal = new bootstrap.Modal(document.getElementById('promoteModal'));
        var disableModal = new bootstrap.Modal(document.getElementById('disableModal'));

        function confirmPromote(userId) {
            currentPromoteId = userId;
            promoteModal.show();
        }

        function cancelPromote() {
            promoteModal.hide();
            var checkbox = document.getElementById('admin-' + currentPromoteId);
            if (checkbox) checkbox.checked = false;
            currentPromoteId = null;
        }

        document.getElementById('promoteConfirmBtn').addEventListener('click', function () {
            if (currentPromoteId) {
                document.getElementById('promote-form-' + currentPromoteId).submit();
            }
        });

        function confirmDisable(userId) {
            currentDisableId = userId;
            disableModal.show();
        }

        document.getElementById('disableConfirmBtn').addEventListener('click', function () {
            if (currentDisableId) {
                document.getElementById('disable-form-' + currentDisableId).submit();
            }
        });
    </script>
}

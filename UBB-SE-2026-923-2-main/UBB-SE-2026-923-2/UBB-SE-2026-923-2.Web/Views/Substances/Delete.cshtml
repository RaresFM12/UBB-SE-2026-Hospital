@model Substance
@{
    ViewData["Title"] = "Delete Substance";
}

<h2 class="mb-4">Delete Substance</h2>

<div class="alert alert-warning" role="alert">
    Are you sure you want to delete this substance?
</div>

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">Lethal Dose</dt>
    <dd class="col-sm-9">@Model.LethalDose.ToString("F2")</dd>

    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@Model.Description</dd>
</dl>

<form asp-controller="Substances" asp-action="Delete" asp-route-name="@Model.Name" method="post">
    <button type="submit" class="btn btn-danger me-2">Delete</button>
    <a asp-controller="Substances" asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

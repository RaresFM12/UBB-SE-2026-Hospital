@model List<Substance>
@{
    ViewData["Title"] = "Substances";
}

<style>
    :root {
        --app-accent: #2F6F5E;
        --app-surface: #F4F8F6;
        --app-text-primary: #111827;
        --app-text-secondary: #4A7D6E;
        --app-error: #DC2626;
        --app-border-radius: 6px;
    }

    .inventory-container {
        padding: 20px;
        background-color: #FFFFFF;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        gap: 15px;
    }

    .nav-tabs-center {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .btn {
        border-radius: var(--app-border-radius);
        font-weight: 500;
        transition: all 0.3s ease;
        border: none;
        padding: 8px 16px;
        font-size: 14px;
        cursor: pointer;
    }

    .btn-primary {
        background-color: var(--app-accent);
        color: white;
    }

    .btn-primary:hover {
        background-color: #2a5d50;
    }

    .btn-secondary {
        background-color: #6B7280;
        color: white;
    }

    .btn-secondary:hover {
        background-color: #4B5563;
    }

    .btn-outline-danger {
        border: 1px solid var(--app-error);
        color: var(--app-error);
        background-color: transparent;
    }

    .btn-outline-danger:hover {
        background-color: #fee2e2;
    }

    .btn-outline-secondary {
        border: 1px solid #6B7280;
        color: #6B7280;
        background-color: transparent;
    }

    .btn-outline-secondary:hover {
        background-color: #f3f4f6;
    }

    .table-wrapper {
        border: 1px solid var(--app-accent);
        border-radius: var(--app-border-radius);
        overflow: hidden;
        flex: 1;
        display: flex;
        flex-direction: column;
        margin-bottom: 20px;
        max-width: 1000px;
        margin-left: auto;
        margin-right: auto;
        align-self: center;
    }

    .table-scroll-container {
        max-height: 500px;
        overflow-y: auto;
        overflow-x: auto;
    }

    .table {
        margin: 0;
        border-collapse: collapse;
        width: 100%;
    }

    .table thead {
        background-color: var(--app-surface);
        border-bottom: 2px solid var(--app-accent);
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .table thead th {
        color: var(--app-text-primary);
        font-weight: 600;
        padding: 12px;
        border: none;
        text-align: left;
        white-space: nowrap;
    }

    .table tbody tr {
        border-bottom: 1px solid var(--app-accent);
        cursor: pointer;
        transition: background-color 0.2s;
    }

    .table tbody tr:hover {
        background-color: var(--app-surface);
    }

    .table tbody tr.selected {
        background-color: #e8f5e9;
    }

    .table tbody td {
        padding: 12px;
        color: var(--app-text-primary);
        vertical-align: middle;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 300px;
    }

    .bottom-actions {
        display: flex;
        justify-content: center;
        gap: 20px;
        padding: 20px;
        border-top: 1px solid var(--app-surface);
    }

    .modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(0, 0, 0, 0.5);
        z-index: 1000;
        align-items: center;
        justify-content: center;
    }

    .modal-overlay.show {
        display: flex;
    }

    .modal-content {
        background-color: white;
        border-radius: var(--app-border-radius);
        padding: 20px;
        max-width: 500px;
        width: 90%;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        border-bottom: 1px solid var(--app-surface);
        padding-bottom: 10px;
    }

    .modal-title {
        font-size: 18px;
        font-weight: 600;
        color: var(--app-text-primary);
    }

    .modal-close {
        background: none;
        border: none;
        font-size: 24px;
        cursor: pointer;
        color: #999;
    }

    .form-group {
        margin-bottom: 15px;
    }

    .form-group label {
        display: block;
        margin-bottom: 5px;
        color: var(--app-text-primary);
        font-weight: 500;
        font-size: 14px;
    }

    .form-group input,
    .form-group textarea {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid var(--app-accent);
        border-radius: var(--app-border-radius);
        font-size: 14px;
        font-family: inherit;
        box-sizing: border-box;
    }

    .form-group textarea {
        min-height: 80px;
        resize: vertical;
    }

    .form-group input:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: var(--app-accent);
        box-shadow: 0 0 0 2px rgba(47, 111, 94, 0.1);
    }

    .modal-buttons {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 20px;
        border-top: 1px solid var(--app-surface);
        padding-top: 15px;
    }

    .no-substances-message {
        text-align: center;
        padding: 40px 20px;
        color: #9CA3AF;
        font-size: 16px;
    }

    .get-data-button {
        margin-bottom: 15px;
        width: 100%;
    }

    .form-row {
        display: flex;
        gap: 15px;
        margin-bottom: 15px;
    }

    .form-row .form-group {
        flex: 1;
        margin-bottom: 0;
    }

    .scrollbar-container::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }

    .scrollbar-container::-webkit-scrollbar-track {
        background: var(--app-surface);
    }

    .scrollbar-container::-webkit-scrollbar-thumb {
        background: var(--app-accent);
        border-radius: 4px;
    }

    .scrollbar-container::-webkit-scrollbar-thumb:hover {
        background: #2a5d50;
    }
</style>

<div class="inventory-container">
    <!-- Top Bar -->
    <div class="top-bar">
        <div></div>
    </div>

    <!-- Center Navigation Buttons -->
    <div class="nav-tabs-center">
        <a asp-controller="Items" asp-action="Index" class="btn btn-secondary">Items</a>
        <button class="btn btn-primary">Substances</button>
        <a asp-controller="Orders" asp-action="Index" class="btn btn-secondary">Orders</a>
    </div>

    <!-- Table -->
    @if (!Model.Any())
    {
        <div class="no-substances-message">
            <p>No substances found.</p>
        </div>
    }
    else
    {
        <div class="table-wrapper">
            <div class="table-scroll-container scrollbar-container">
                <table class="table" id="substancesTable">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Lethal Dose</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (Substance substance in Model)
                        {
                            <tr class="data-row" data-name="@substance.Name" onclick="selectRow(this)">
                                <td>@substance.Name</td>
                                <td>@substance.LethalDose.ToString("F2")</td>
                                <td>@substance.Description</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- Bottom Action Buttons -->
    <div class="bottom-actions">
        <button class="btn btn-primary" onclick="openAddModal()">Add</button>
        <button class="btn btn-primary" onclick="openUpdateModal()">Update</button>
        <button class="btn btn-outline-danger" onclick="removeSubstance()">Remove</button>
    </div>
</div>

<!-- Add Substance Modal -->
<div id="addModal" class="modal-overlay">
    <div class="modal-content">
        <div class="modal-header">
            <h2 class="modal-title">Add Substance</h2>
            <button class="modal-close" onclick="closeAddModal()">&times;</button>
        </div>

        <form id="addSubstanceForm">
            <div class="form-group">
                <label>Name *</label>
                <input type="text" id="addName" name="Name" required>
            </div>

            <div class="form-group">
                <label>Lethal Dose *</label>
                <input type="number" id="addLethalDose" name="LethalDose" step="0.01" required>
            </div>

            <div class="form-group">
                <label>Description</label>
                <textarea id="addDescription" name="Description"></textarea>
            </div>

            <div class="modal-buttons">
                <button type="button" class="btn btn-outline-secondary" onclick="closeAddModal()">Cancel</button>
                <button type="submit" class="btn btn-primary">Add Substance</button>
            </div>
        </form>
    </div>
</div>

<!-- Update Substance Modal -->
<div id="updateModal" class="modal-overlay">
    <div class="modal-content">
        <div class="modal-header">
            <h2 class="modal-title">Update Substance</h2>
            <button class="modal-close" onclick="closeUpdateModal()">&times;</button>
        </div>

        <form id="updateSubstanceForm">
            <div class="form-group">
                <label>Name *</label>
                <input type="text" id="updateName" name="Name" required>
            </div>

            <button type="button" class="btn btn-primary get-data-button" onclick="getSubstanceData()">Get Substance Data</button>

            <div class="form-group">
                <label>Lethal Dose *</label>
                <input type="number" id="updateLethalDose" name="LethalDose" step="0.01" required>
            </div>

            <div class="form-group">
                <label>Description</label>
                <textarea id="updateDescription" name="Description"></textarea>
            </div>

            <div class="modal-buttons">
                <button type="button" class="btn btn-outline-secondary" onclick="closeUpdateModal()">Cancel</button>
                <button type="submit" class="btn btn-primary">Update Substance</button>
            </div>
        </form>
    </div>
</div>

<script>
    let selectedRow = null;
    const allSubstances = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model, new Newtonsoft.Json.JsonSerializerSettings { NullValueHandling = Newtonsoft.Json.NullValueHandling.Ignore }));

    function selectRow(row) {
        if (selectedRow) {
            selectedRow.classList.remove('selected');
        }
        row.classList.add('selected');
        selectedRow = row;
    }

    function openAddModal() {
        document.getElementById('addModal').classList.add('show');
        document.getElementById('addSubstanceForm').reset();
    }

    function closeAddModal() {
        document.getElementById('addModal').classList.remove('show');
    }

    function openUpdateModal() {
        document.getElementById('updateModal').classList.add('show');
        document.getElementById('updateName').focus();
    }

    function closeUpdateModal() {
        document.getElementById('updateModal').classList.remove('show');
    }

    function getSubstanceData() {
        const substanceName = document.getElementById('updateName').value;
        if (!substanceName) {
            alert('Please enter a substance name first!');
            return;
        }

        const substance = allSubstances.find(substanceNew => substanceNew.Name.toLowerCase() === substanceName.toLowerCase());
        if (substance) {
            document.getElementById('updateLethalDose').value = substance.LethalDose || '';
            document.getElementById('updateDescription').value = substance.Description || '';
        } else {
            alert('Substance not found!');
            console.log('Available substances:', allSubstances);
            console.log('Searching for name:', substanceName);
        }
    }

    function removeSubstance() {
        if (!selectedRow) {
            alert('Please select a substance first!');
            return;
        }

        if (confirm('Are you sure you want to delete this substance?')) {
            const substanceName = selectedRow.dataset.name;
            window.location.href = `/Substances/Delete?name=${encodeURIComponent(substanceName)}`;
        }
    }

    document.getElementById('addSubstanceForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        const formData = new FormData(this);
        try {
            const response = await fetch('/Substances/Create', {
                method: 'POST',
                body: formData
            });
            if (response.ok) {
                location.reload();
            }
        } catch (error) {
            alert('Error adding substance: ' + error);
        }
    });

    document.getElementById('updateSubstanceForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        const formData = new FormData(this);
        const substanceName = document.getElementById('updateName').value;
        try {
            const response = await fetch(`/Substances/Edit?name=${encodeURIComponent(substanceName)}`, {
                method: 'POST',
                body: formData
            });
            if (response.ok) {
                location.reload();
            }
        } catch (error) {
            alert('Error updating substance: ' + error);
        }
    });
</script>

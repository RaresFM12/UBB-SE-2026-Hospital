@model Substance
@{
    ViewData["Title"] = "Substance Details";
}

<h2 class="mb-4">Substance Details</h2>

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">Lethal Dose</dt>
    <dd class="col-sm-9">@Model.LethalDose.ToString("F2")</dd>

    <dt class="col-sm-3">Description</dt>
    <dd class="col-sm-9">@Model.Description</dd>
</dl>

<div class="mt-3">
    <a asp-controller="Substances" asp-action="Edit" asp-route-name="@Model.Name" class="btn btn-primary me-2">Edit</a>
    <a asp-controller="Substances" asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

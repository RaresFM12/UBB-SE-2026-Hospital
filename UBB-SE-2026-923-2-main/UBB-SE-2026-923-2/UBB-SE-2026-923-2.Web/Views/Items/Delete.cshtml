@model Item
@{
    ViewData["Title"] = "Delete Item";
}

<h2 class="mb-4">Delete Item</h2>

<div class="alert alert-warning" role="alert">
    Are you sure you want to delete this item?
</div>

<dl class="row">
    <dt class="col-sm-3">Name</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">Producer</dt>
    <dd class="col-sm-9">@Model.Producer</dd>

    <dt class="col-sm-3">Category</dt>
    <dd class="col-sm-9">@Model.Category</dd>

    <dt class="col-sm-3">Price</dt>
    <dd class="col-sm-9">@Model.Price.ToString("F2")</dd>

    <dt class="col-sm-3">Quantity</dt>
    <dd class="col-sm-9">@Model.Quantity</dd>
</dl>

<form asp-controller="Items" asp-action="Delete" method="post">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger me-2">Delete</button>
    <a asp-controller="Items" asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

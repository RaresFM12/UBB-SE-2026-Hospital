@model ItemIndexViewModel
@{
    ViewData["Title"] = "Inventory";
}

<style>
    :root {
        --app-accent: #2F6F5E;
        --app-surface: #F4F8F6;
        --app-text-primary: #111827;
        --app-text-secondary: #4A7D6E;
        --app-error: #DC2626;
        --app-border-radius: 6px;
    }

    body > .container {
        max-width: none;
        width: 100%;
        padding-left: 16px;
        padding-right: 16px;
    }

    .inventory-container {
        padding: 20px;
        background-color: #FFFFFF;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        width: 100%;
        max-width: 1700px;
        margin: 0 auto;
        box-sizing: border-box;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        gap: 15px;
        flex-wrap: wrap;
    }

    .inventory-filter-form {
        display: none;
    }

    .left-controls {
        display: flex;
        gap: 10px;
    }

    .right-controls {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .nav-tabs-center {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .btn {
        border-radius: var(--app-border-radius);
        font-weight: 500;
        transition: all 0.3s ease;
        border: none;
        padding: 8px 16px;
        font-size: 14px;
        cursor: pointer;
    }

    .btn-primary {
        background-color: var(--app-accent);
        color: white;
    }

    .btn-primary:hover {
        background-color: #2a5d50;
    }

    .btn-secondary {
        background-color: #6B7280;
        color: white;
    }

    .btn-secondary:hover {
        background-color: #4B5563;
    }

    .btn-info {
        background-color: #0891b2;
        color: white;
    }

    .btn-info:hover {
        background-color: #0e7490;
    }

    .btn-outline-primary {
        border: 1px solid var(--app-accent);
        color: var(--app-accent);
        background-color: transparent;
    }

    .btn-outline-primary:hover {
        background-color: var(--app-accent);
        color: white;
    }

    .btn-outline-danger {
        border: 1px solid var(--app-error);
        color: var(--app-error);
        background-color: transparent;
    }

    .btn-outline-danger:hover {
        background-color: #fee2e2;
    }

    .btn-outline-secondary {
        border: 1px solid #6B7280;
        color: #6B7280;
        background-color: transparent;
    }

    .btn-outline-secondary:hover {
        background-color: #f3f4f6;
    }

    .search-container {
        margin-bottom: 20px;
        text-align: center;
    }

    .search-label {
        display: block;
        margin-bottom: 8px;
        color: var(--app-text-primary);
        font-weight: 500;
    }

    .search-input {
        border: 1px solid var(--app-accent);
        border-radius: var(--app-border-radius);
        padding: 8px 12px;
        font-size: 14px;
        width: 100%;
        max-width: none;
        box-sizing: border-box;
    }

    .toggle-switch {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .toggle-switch input[type="checkbox"] {
        width: 40px;
        height: 24px;
        cursor: pointer;
        appearance: none;
        background-color: #ddd;
        border-radius: 12px;
        outline: none;
        position: relative;
        transition: background-color 0.3s;
    }

    .toggle-switch input[type="checkbox"]:checked {
        background-color: var(--app-accent);
    }

    .toggle-switch input[type="checkbox"]:before {
        content: '';
        position: absolute;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background-color: white;
        top: 2px;
        left: 2px;
        transition: left 0.3s;
    }

    .toggle-switch input[type="checkbox"]:checked:before {
        left: 18px;
    }

    .toggle-switch label {
        color: var(--app-text-primary);
        font-weight: 500;
        cursor: pointer;
        margin: 0;
    }

    .table-wrapper {
        border: 1px solid var(--app-accent);
        border-radius: var(--app-border-radius);
        overflow: hidden;
        flex: 1;
        display: flex;
        flex-direction: column;
        margin-bottom: 20px;
        width: 100%;
        max-width: none;
        margin-left: auto;
        margin-right: auto;
        align-self: stretch;
    }

    .table-scroll-container {
        max-height: 500px;
        overflow-y: auto;
        overflow-x: auto;
        width: 100%;
    }

    .table {
        margin: 0;
        border-collapse: collapse;
        width: 100%;
        min-width: 1420px;
        table-layout: fixed;
    }

    .table thead {
        background-color: var(--app-surface);
        border-bottom: 2px solid var(--app-accent);
        position: sticky;
        top: 0;
        z-index: 10;
    }

    .table thead th {
        color: var(--app-text-primary);
        font-weight: 600;
        padding: 12px;
        border: none;
        text-align: left;
        white-space: nowrap;
    }

    .table tbody {
        display: table-row-group;
    }

    .table tbody tr {
        border-bottom: 1px solid var(--app-accent);
        cursor: pointer;
        transition: background-color 0.2s;
    }

    .table tbody tr:hover {
        background-color: var(--app-surface);
    }

    .table tbody tr.selected {
        background-color: #e8f5e9;
    }

    .table tbody td {
        padding: 12px;
        color: var(--app-text-primary);
        vertical-align: middle;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 200px;
    }

    .bottom-actions {
        display: flex;
        justify-content: center;
        gap: 20px;
        padding: 20px;
        border-top: 1px solid var(--app-surface);
    }

    .modal-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(0, 0, 0, 0.5);
        z-index: 1000;
        align-items: center;
        justify-content: center;
    }

    .modal-overlay.show {
        display: flex;
    }

    .modal-content {
        background-color: white;
        border-radius: var(--app-border-radius);
        padding: 20px;
        max-width: 860px;
        width: 90%;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
    }

    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        border-bottom: 1px solid var(--app-surface);
        padding-bottom: 10px;
    }

    .modal-title {
        font-size: 18px;
        font-weight: 600;
        color: var(--app-text-primary);
    }

    .modal-close {
        background: none;
        border: none;
        font-size: 24px;
        cursor: pointer;
        color: #999;
    }

    .form-group {
        margin-bottom: 15px;
    }

    .form-group label {
        display: block;
        margin-bottom: 5px;
        color: var(--app-text-primary);
        font-weight: 500;
        font-size: 14px;
    }

    .form-group input,
    .form-group textarea {
        width: 100%;
        padding: 8px 12px;
        border: 1px solid var(--app-accent);
        border-radius: var(--app-border-radius);
        font-size: 14px;
        font-family: inherit;
        box-sizing: border-box;
    }

    .form-group textarea {
        min-height: 80px;
        resize: vertical;
    }

    .form-group input:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: var(--app-accent);
        box-shadow: 0 0 0 2px rgba(47, 111, 94, 0.1);
    }

    .form-row {
        display: flex;
        gap: 15px;
        margin-bottom: 15px;
    }

    .form-row .form-group {
        flex: 1;
        margin-bottom: 0;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 15px;
    }

    .form-grid .form-group.full-width,
    .collection-section {
        grid-column: 1 / -1;
    }

    .collection-section {
        margin-top: 10px;
    }

    .collection-list {
        border: 1px solid var(--app-accent);
        border-radius: var(--app-border-radius);
        min-height: 120px;
        max-height: 170px;
        overflow-y: auto;
        margin-bottom: 10px;
    }

    .collection-table {
        width: 100%;
        border-collapse: collapse;
    }

    .collection-table th,
    .collection-table td {
        padding: 8px 10px;
        border-bottom: 1px solid var(--app-surface);
        color: var(--app-text-primary);
        font-size: 14px;
    }

    .collection-table th {
        background-color: var(--app-surface);
        font-weight: 600;
    }

    .collection-row {
        cursor: pointer;
    }

    .collection-row.selected {
        background-color: #e8f5e9;
    }

    .inline-builder {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(120px, 180px) auto auto;
        gap: 10px;
        align-items: end;
    }

    .hidden-serialized-field {
        display: none;
    }

    @@media (max-width: 760px) {
        .form-grid,
        .inline-builder {
            grid-template-columns: 1fr;
        }
    }

    .modal-buttons {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 20px;
        border-top: 1px solid var(--app-surface);
        padding-top: 15px;
    }

    .error-message {
        color: var(--app-error);
        font-size: 13px;
        margin-top: 5px;
    }

    .no-items-message {
        text-align: center;
        padding: 40px 20px;
        color: #9CA3AF;
        font-size: 16px;
    }

    .get-data-button {
        margin-bottom: 15px;
        width: 100%;
    }

    .form-section-title {
        font-size: 14px;
        font-weight: 600;
        color: var(--app-text-primary);
        margin-top: 15px;
        margin-bottom: 10px;
    }

    .scrollbar-container::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }

    .scrollbar-container::-webkit-scrollbar-track {
        background: var(--app-surface);
    }

    .scrollbar-container::-webkit-scrollbar-thumb {
        background: var(--app-accent);
        border-radius: 4px;
    }

    .scrollbar-container::-webkit-scrollbar-thumb:hover {
        background: #2a5d50;
    }
</style>

<div class="inventory-container">
    <form id="inventoryFilterForm" asp-controller="Items" asp-action="Index" method="get" class="inventory-filter-form"></form>

    <!-- Top Bar with Statistics and Toggle -->
    <div class="top-bar">
        <div class="left-controls">
            <a asp-controller="Statistics" asp-action="Index" class="btn btn-info">Statistics</a>
        </div>
        <div class="right-controls">
            <span style="color: var(--app-text-primary); font-weight: 500;">Show expired items</span>
            <div class="toggle-switch">
                <input type="checkbox" id="showExpiredToggle" name="showExpiredOnly" value="true" form="inventoryFilterForm" @(Model.ShowExpiredOnly ? "checked" : string.Empty) onchange="submitInventoryFilters()">
            </div>
        </div>
    </div>

    <!-- Center Navigation Buttons -->
    <div class="nav-tabs-center">
        <button class="btn btn-primary">Items</button>
        <a asp-controller="Substances" asp-action="Index" class="btn btn-secondary">Substances</a>
        <a asp-controller="Orders" asp-action="Manage" class="btn btn-secondary">Orders</a>
    </div>

    <!-- Search Bar -->
    <div class="search-container">
        <label class="search-label">Search by name</label>
        <input type="text" id="searchInput" name="searchQuery" value="@Model.SearchQuery" form="inventoryFilterForm" class="search-input" placeholder="Enter name..." oninput="filterItems()">
    </div>

    <!-- Table -->
    @if (!Model.Items.Any())
    {
        <div class="no-items-message">
            <p>No items found.</p>
        </div>
    }
    else
    {
        <div class="table-wrapper">
            <div class="table-scroll-container scrollbar-container">
                <table class="table" id="itemsTable">
                    <thead>
                        <tr>
                            <th style="width: 50px;">ID</th>
                            <th style="width: 170px;">Name</th>
                            <th style="width: 170px;">Producer</th>
                            <th style="width: 90px;">Price</th>
                            <th style="width: 150px;">Category</th>
                            <th style="width: 360px;">Description</th>
                            <th style="width: 80px;">Pills</th>
                            <th style="width: 90px;">Quantity</th>
                            <th style="width: 170px;">Label</th>
                            <th style="width: 90px;">Discount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (Item item in Model.Items)
                        {
                            <tr class="data-row" data-id="@item.Id" data-name="@item.Name" onclick="selectRow(this)">
                                <td>@item.Id</td>
                                <td>@item.Name</td>
                                <td>@item.Producer</td>
                                <td>@item.Price.ToString("F2")</td>
                                <td>@item.Category</td>
                                <td>@item.Description</td>
                                <td>@item.NumberOfPills</td>
                                <td>@item.Quantity</td>
                                <td>@item.Label</td>
                                <td>@item.DiscountPercentage</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- Bottom Action Buttons -->
    <div class="bottom-actions">
        <button class="btn btn-primary" onclick="openAddModal()">Add</button>
        <button class="btn btn-primary" onclick="openUpdateModal()">Update</button>
        <button class="btn btn-outline-danger" onclick="removeItem()">Remove</button>
    </div>
</div>

<!-- Add Item Modal -->
<div id="addModal" class="modal-overlay">
    <div class="modal-content">
        <div class="modal-header">
            <h2 class="modal-title">Add Item</h2>
            <button class="modal-close" onclick="closeAddModal()">&times;</button>
        </div>

        <form id="addItemForm" asp-controller="Items" asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div class="form-grid">
                <div class="form-group">
                    <label>Name *</label>
                    <input type="text" id="addName" name="Name" placeholder="Enter product name" required>
                </div>

                <div class="form-group">
                    <label>Producer *</label>
                    <input type="text" id="addProducer" name="Producer" placeholder="Enter producer" required>
                </div>

                <div class="form-group">
                    <label>Price *</label>
                    <input type="number" id="addPrice" name="Price" step="0.01" min="0.01" placeholder="Enter price" required>
                </div>

                <div class="form-group">
                    <label>Category *</label>
                    <input type="text" id="addCategory" name="Category" placeholder="Enter category" required>
                </div>

                <div class="form-group">
                    <label>Image Path</label>
                    <input type="text" id="addImagePath" name="ImagePath" placeholder="Enter image path">
                </div>

                <div class="form-group">
                    <label>Number of Pills *</label>
                    <input type="number" id="addNumberOfPills" name="NumberOfPills" min="1" placeholder="Enter number" required>
                </div>

                <div class="form-group">
                    <label>Label</label>
                    <input type="text" id="addLabel" name="Label" placeholder="Enter label">
                </div>

                <div class="form-group full-width">
                    <label>Description</label>
                    <textarea id="addDescription" name="Description" placeholder="Enter description"></textarea>
                </div>

                <div class="form-group">
                    <label>Discount (%)</label>
                    <input type="number" id="addDiscount" name="DiscountPercentage" step="0.01" min="0" max="100" placeholder="Enter discount">
                </div>

                <div class="collection-section">
                    <div class="form-section-title">Active Substances</div>
                    <div class="collection-list scrollbar-container">
                        <table class="collection-table">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Concentration</th>
                                </tr>
                            </thead>
                            <tbody id="addActiveSubstancesBody"></tbody>
                        </table>
                    </div>
                    <div class="inline-builder">
                        <div class="form-group">
                            <label>Name</label>
                            <input type="text" id="addSubstanceName">
                        </div>
                        <div class="form-group">
                            <label>Concentration</label>
                            <input type="number" id="addConcentration" step="0.01">
                        </div>
                        <button type="button" class="btn btn-primary" onclick="addSubstanceToForm('add')">Add Substance</button>
                        <button type="button" class="btn btn-outline-danger" onclick="removeSubstanceFromForm('add')">Remove Substance</button>
                    </div>
                    <textarea id="addSubstancesText" name="SubstancesText" class="hidden-serialized-field"></textarea>
                </div>

                <div class="collection-section">
                    <div class="form-section-title">Batches</div>
                    <div class="collection-list scrollbar-container">
                        <table class="collection-table">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Packs</th>
                                </tr>
                            </thead>
                            <tbody id="addBatchesBody"></tbody>
                        </table>
                    </div>
                    <div class="inline-builder">
                        <div class="form-group">
                            <label>Date</label>
                            <input type="date" id="addBatchDate">
                        </div>
                        <div class="form-group">
                            <label>Number of Packs</label>
                            <input type="number" id="addBatchPacks">
                        </div>
                        <button type="button" class="btn btn-primary" onclick="addBatchToForm('add')">Add Batch</button>
                        <button type="button" class="btn btn-outline-danger" onclick="removeBatchFromForm('add')">Remove Batch</button>
                    </div>
                    <textarea id="addBatchesText" name="BatchesText" class="hidden-serialized-field"></textarea>
                </div>
            </div>

            <div class="modal-buttons">
                <button type="button" class="btn btn-outline-secondary" onclick="closeAddModal()">Cancel</button>
                <button type="submit" class="btn btn-primary">Add Item</button>
            </div>
        </form>
    </div>
</div>

<!-- Update Item Modal -->
<div id="updateModal" class="modal-overlay">
    <div class="modal-content">
        <div class="modal-header">
            <h2 class="modal-title">Update Item</h2>
            <button class="modal-close" onclick="closeUpdateModal()">&times;</button>
        </div>

        <form id="updateItemForm" method="post">
            @Html.AntiForgeryToken()

            <button type="button" class="btn btn-primary get-data-button" onclick="getItemData()">Get Item Data</button>

            <div class="form-grid">
                <div class="form-group">
                    <label>Id *</label>
                    <input type="number" id="updateId" name="Id" placeholder="Enter product id" required>
                </div>

                <div class="form-group">
                    <label>Name *</label>
                    <input type="text" id="updateName" name="Name" placeholder="Enter product name" required>
                </div>

                <div class="form-group">
                    <label>Producer *</label>
                    <input type="text" id="updateProducer" name="Producer" placeholder="Enter producer" required>
                </div>

                <div class="form-group">
                    <label>Price *</label>
                    <input type="number" id="updatePrice" name="Price" step="0.01" min="0.01" placeholder="Enter price" required>
                </div>

                <div class="form-group">
                    <label>Category *</label>
                    <input type="text" id="updateCategory" name="Category" placeholder="Enter category" required>
                </div>

                <div class="form-group">
                    <label>Image Path</label>
                    <input type="text" id="updateImagePath" name="ImagePath" placeholder="Enter image path">
                </div>

                <div class="form-group">
                    <label>Number of Pills *</label>
                    <input type="number" id="updateNumberOfPills" name="NumberOfPills" min="1" placeholder="Enter number" required>
                </div>

                <div class="form-group">
                    <label>Label</label>
                    <input type="text" id="updateLabel" name="Label" placeholder="Enter label">
                </div>

                <div class="form-group full-width">
                    <label>Description</label>
                    <textarea id="updateDescription" name="Description" placeholder="Enter description"></textarea>
                </div>

                <div class="form-group">
                    <label>Discount (%)</label>
                    <input type="number" id="updateDiscount" name="DiscountPercentage" step="0.01" min="0" max="100" placeholder="Enter discount">
                </div>

                <div class="collection-section">
                    <div class="form-section-title">Active Substances</div>
                    <div class="collection-list scrollbar-container">
                        <table class="collection-table">
                            <thead>
                                <tr>
                                    <th>Name</th>
                                    <th>Concentration</th>
                                </tr>
                            </thead>
                            <tbody id="updateActiveSubstancesBody"></tbody>
                        </table>
                    </div>
                    <div class="inline-builder">
                        <div class="form-group">
                            <label>Name</label>
                            <input type="text" id="updateSubstanceName">
                        </div>
                        <div class="form-group">
                            <label>Concentration</label>
                            <input type="number" id="updateConcentration" step="0.01">
                        </div>
                        <button type="button" class="btn btn-primary" onclick="addSubstanceToForm('update')">Add Substance</button>
                        <button type="button" class="btn btn-outline-danger" onclick="removeSubstanceFromForm('update')">Remove Substance</button>
                    </div>
                    <textarea id="updateSubstancesText" name="SubstancesText" class="hidden-serialized-field"></textarea>
                </div>

                <div class="collection-section">
                    <div class="form-section-title">Batches</div>
                    <div class="collection-list scrollbar-container">
                        <table class="collection-table">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Packs</th>
                                </tr>
                            </thead>
                            <tbody id="updateBatchesBody"></tbody>
                        </table>
                    </div>
                    <div class="inline-builder">
                        <div class="form-group">
                            <label>Date</label>
                            <input type="date" id="updateBatchDate">
                        </div>
                        <div class="form-group">
                            <label>Number of Packs</label>
                            <input type="number" id="updateBatchPacks">
                        </div>
                        <button type="button" class="btn btn-primary" onclick="addBatchToForm('update')">Add Batch</button>
                        <button type="button" class="btn btn-outline-danger" onclick="removeBatchFromForm('update')">Remove Batch</button>
                    </div>
                    <textarea id="updateBatchesText" name="BatchesText" class="hidden-serialized-field"></textarea>
                </div>
            </div>

            <div class="modal-buttons">
                <button type="button" class="btn btn-outline-secondary" onclick="closeUpdateModal()">Cancel</button>
                <button type="submit" class="btn btn-primary">Update Item</button>
            </div>
        </form>
    </div>
</div>

<script>
    let selectedRow = null;
    let updateItemLoaded = false;
    const allItems = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.Items, new Newtonsoft.Json.JsonSerializerSettings { NullValueHandling = Newtonsoft.Json.NullValueHandling.Ignore }));
    const itemFormState = {
        add: { substances: {}, batches: {}, selectedBatch: null },
        update: { substances: {}, batches: {}, selectedBatch: null },
    };

    function selectRow(row) {
        if (selectedRow) {
            selectedRow.classList.remove('selected');
        }
        row.classList.add('selected');
        selectedRow = row;
    }

    function openAddModal() {
        document.getElementById('addItemForm').reset();
        resetItemFormState('add');
        document.getElementById('addModal').classList.add('show');
    }

    function closeAddModal() {
        document.getElementById('addModal').classList.remove('show');
    }

    function openUpdateModal() {
        document.getElementById('updateItemForm').reset();
        resetItemFormState('update');
        updateItemLoaded = false;
        document.getElementById('updateModal').classList.add('show');
        document.getElementById('updateId').focus();
    }

    function closeUpdateModal() {
        document.getElementById('updateModal').classList.remove('show');
    }

    function submitInventoryFilters() {
        document.getElementById('inventoryFilterForm').submit();
    }

    function resetItemFormState(mode) {
        itemFormState[mode].substances = {};
        itemFormState[mode].batches = {};
        itemFormState[mode].selectedBatch = null;
        renderSubstances(mode);
        renderBatches(mode);
    }

    function updateSerializedFields(mode) {
        const state = itemFormState[mode];
        document.getElementById(`${mode}SubstancesText`).value = Object.entries(state.substances)
            .map(([name, concentration]) => `${name}:${concentration}`)
            .join('\n');
        document.getElementById(`${mode}BatchesText`).value = Object.entries(state.batches)
            .map(([date, packs]) => `${date}:${packs}`)
            .join('\n');
    }

    function renderSubstances(mode) {
        const body = document.getElementById(`${mode}ActiveSubstancesBody`);
        const entries = Object.entries(itemFormState[mode].substances);
        body.innerHTML = entries.length
            ? entries.map(([name, concentration]) => `
                <tr class="collection-row" onclick="fillSubstanceInputs('${mode}', '${escapeJs(name)}')">
                    <td>${escapeHtml(name)}</td>
                    <td>${escapeHtml(String(concentration))}</td>
                </tr>`).join('')
            : '<tr><td colspan="2" class="text-muted">No active substances added.</td></tr>';
        updateSerializedFields(mode);
    }

    function renderBatches(mode) {
        const body = document.getElementById(`${mode}BatchesBody`);
        const state = itemFormState[mode];
        const entries = Object.entries(state.batches).sort(([left], [right]) => left.localeCompare(right));
        body.innerHTML = entries.length
            ? entries.map(([date, packs]) => `
                <tr class="collection-row ${state.selectedBatch === date ? 'selected' : ''}" onclick="selectBatch('${mode}', '${date}')">
                    <td>${escapeHtml(date)}</td>
                    <td>${escapeHtml(String(packs))}</td>
                </tr>`).join('')
            : '<tr><td colspan="2" class="text-muted">No batches added.</td></tr>';
        updateSerializedFields(mode);
    }

    function addSubstanceToForm(mode) {
        const nameInput = document.getElementById(`${mode}SubstanceName`);
        const concentrationInput = document.getElementById(`${mode}Concentration`);
        const name = nameInput.value.trim();
        const concentration = Number.parseFloat(concentrationInput.value);

        if (!name || Number.isNaN(concentration)) {
            alert('Add a substance name and a valid concentration.');
            return;
        }

        itemFormState[mode].substances[name] = concentration;
        nameInput.value = '';
        concentrationInput.value = '';
        renderSubstances(mode);
    }

    function removeSubstanceFromForm(mode) {
        const nameInput = document.getElementById(`${mode}SubstanceName`);
        const name = nameInput.value.trim();
        if (!name || !Object.prototype.hasOwnProperty.call(itemFormState[mode].substances, name)) {
            alert('Insert the name of a valid substance to remove it.');
            return;
        }

        delete itemFormState[mode].substances[name];
        nameInput.value = '';
        document.getElementById(`${mode}Concentration`).value = '';
        renderSubstances(mode);
    }

    function fillSubstanceInputs(mode, name) {
        document.getElementById(`${mode}SubstanceName`).value = name;
        document.getElementById(`${mode}Concentration`).value = itemFormState[mode].substances[name];
    }

    function addBatchToForm(mode) {
        const dateInput = document.getElementById(`${mode}BatchDate`);
        const packsInput = document.getElementById(`${mode}BatchPacks`);
        const date = dateInput.value;
        const packs = Number.parseInt(packsInput.value, 10);
        const today = new Date().toISOString().slice(0, 10);

        if (!date || Number.isNaN(packs)) {
            alert('Add a batch date and a valid number of packs.');
            return;
        }

        if (date <= today) {
            alert('The expiration date must be later than the current date.');
            return;
        }

        itemFormState[mode].batches[date] = packs;
        itemFormState[mode].selectedBatch = date;
        packsInput.value = '';
        renderBatches(mode);
    }

    function selectBatch(mode, date) {
        itemFormState[mode].selectedBatch = date;
        document.getElementById(`${mode}BatchDate`).value = date;
        document.getElementById(`${mode}BatchPacks`).value = itemFormState[mode].batches[date];
        renderBatches(mode);
    }

    function removeBatchFromForm(mode) {
        const dateInput = document.getElementById(`${mode}BatchDate`);
        const date = itemFormState[mode].selectedBatch || dateInput.value;
        if (!date || !Object.prototype.hasOwnProperty.call(itemFormState[mode].batches, date)) {
            alert('Select a batch first.');
            return;
        }

        delete itemFormState[mode].batches[date];
        itemFormState[mode].selectedBatch = null;
        dateInput.value = '';
        document.getElementById(`${mode}BatchPacks`).value = '';
        renderBatches(mode);
    }

    function normalizeSubstances(substances) {
        const result = {};
        for (const [name, concentration] of Object.entries(substances || {})) {
            result[name] = Number.parseFloat(concentration);
        }

        return result;
    }

    function normalizeBatches(batches) {
        const result = {};
        for (const [rawDate, packs] of Object.entries(batches || {})) {
            const date = rawDate.slice(0, 10);
            result[date] = Number.parseInt(packs, 10);
        }

        return result;
    }

    function prepareItemForm(mode) {
        const discountInput = document.getElementById(`${mode}Discount`);
        if (!discountInput.value.trim()) {
            discountInput.value = '0';
        }

        updateSerializedFields(mode);
        if (Object.keys(itemFormState[mode].substances).length === 0) {
            alert('Add at least one active substance.');
            return false;
        }

        return true;
    }

    function escapeHtml(value) {
        return value.replace(/[&<>"']/g, character => ({
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '"': '&quot;',
            "'": '&#39;',
        }[character]));
    }

    function escapeJs(value) {
        return value
            .replace(/\\/g, '\\\\')
            .replace(/'/g, "\\'")
            .replace(/"/g, '&quot;')
            .replace(/\r?\n/g, ' ');
    }

    function getItemData() {
        const itemId = document.getElementById('updateId').value;
        if (!itemId) {
            alert('Please enter an item ID first!');
            return;
        }

        const item = allItems.find(itemNew => itemNew.Id == itemId);
        if (item) {
            document.getElementById('updateName').value = item.Name || '';
            document.getElementById('updateProducer').value = item.Producer || '';
            document.getElementById('updatePrice').value = item.Price || '';
            document.getElementById('updateCategory').value = item.Category || '';
            document.getElementById('updateImagePath').value = item.ImagePath || '';
            document.getElementById('updateNumberOfPills').value = item.NumberOfPills || '';
            document.getElementById('updateLabel').value = item.Label || '';
            document.getElementById('updateDescription').value = item.Description || '';
            document.getElementById('updateDiscount').value = item.DiscountPercentage || '';
            itemFormState.update.substances = normalizeSubstances(item.ActiveSubstances);
            itemFormState.update.batches = normalizeBatches(item.Batches);
            itemFormState.update.selectedBatch = null;
            renderSubstances('update');
            renderBatches('update');
            updateItemLoaded = true;
        } else {
            alert('Item not found!');
            console.log('Available items:', allItems);
            console.log('Searching for ID:', itemId);
        }
    }

    function filterItems() {
        const searchValue = document.getElementById('searchInput').value.toLowerCase();
        const rows = document.querySelectorAll('.data-row');

        rows.forEach(row => {
            const name = row.dataset.name.toLowerCase();
            const matchesSearch = name.includes(searchValue);
            row.style.display = matchesSearch ? '' : 'none';
        });
    }

    function removeItem() {
        if (!selectedRow) {
            alert('Please select an item first!');
            return;
        }

        if (confirm('Are you sure you want to delete this item?')) {
            const itemId = selectedRow.dataset.id;
            window.location.href = `/Items/Delete?id=${itemId}`;
        }
    }

    document.getElementById('addItemForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        if (!this.checkValidity()) {
            this.reportValidity();
            return;
        }

        if (!prepareItemForm('add')) {
            return;
        }

        const formData = new FormData(this);
        try {
            const response = await fetch('/Items/Create', {
                method: 'POST',
                body: formData
            });
            if (response.ok) {
                location.reload();
            } else {
                alert('Error adding item.');
            }
        } catch (error) {
            alert('Error adding item: ' + error);
        }
    });

    document.getElementById('updateItemForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        if (!updateItemLoaded) {
            alert('Please click "Get Item Data" before changing anything.');
            return;
        }

        if (!this.checkValidity()) {
            this.reportValidity();
            return;
        }

        if (!prepareItemForm('update')) {
            return;
        }

        const formData = new FormData(this);
        const itemId = document.getElementById('updateId').value;
        try {
            const response = await fetch(`/Items/Edit?id=${itemId}`, {
                method: 'POST',
                body: formData
            });
            if (response.ok) {
                location.reload();
            } else {
                alert('Error updating item.');
            }
        } catch (error) {
            alert('Error updating item: ' + error);
        }
    });

    resetItemFormState('add');
    resetItemFormState('update');
</script>

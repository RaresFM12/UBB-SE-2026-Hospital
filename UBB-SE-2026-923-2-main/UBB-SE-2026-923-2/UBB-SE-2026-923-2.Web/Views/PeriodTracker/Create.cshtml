@model UBB_SE_2026_923_2.Web.ViewModels.PeriodTrackerViewModel
@{
    ViewData["Title"] = "Initialize Cycle Profile";
}

<div class="container mt-4" style="max-width: 500px;">
    <div class="card shadow-sm border-0 border-top border-success border-3">
        <div class="card-header bg-dark text-white fw-bold">
            <h5 class="mb-0 small text-uppercase py-1">??? Initialize Tracker Framework</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label small fw-bold">Start Period Date</label>
                    <input type="date" class="form-control" name="StartPeriodDate" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold">Cycle Days Interval Boundary (20-45)</label>
                    <input type="number" class="form-control" name="CycleDays" min="20" max="45" value="28" required />
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold">Average Period Duration (1-9 Days)</label>
                    <input type="number" class="form-control" name="PeriodLasts" min="1" max="9" value="5" required />
                </div>
                <div class="mb-4">
                    <label class="form-label small fw-bold">When do PMS symptoms appear:</label>
                    <select class="form-select" name="PMSOption">
                        <option value="0">Not applicable</option>
                        <option value="1">1-3 days before period</option>
                        <option value="2">4-7 days before period</option>
                        <option value="3">7-14 days before period</option>
                    </select>
                </div>
                <div class="d-flex justify-content-between border-top pt-3">
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary px-3">Cancel</a>
                    <button type="submit" class="btn btn-sm btn-success px-4 fw-bold">CALCULATE</button>
                </div>
            </form>
        </div>
    </div>
</div>
@model UBB_SE_2026_923_2.Web.ViewModels.PeriodTrackerViewModel
@{
    ViewData["Title"] = "Update Cycle Configuration";
}

<div class="container mt-4" style="max-width: 500px;">
    <div class="card shadow-sm border-0 border-top border-primary border-3">
        <div class="card-header bg-dark text-white fw-bold">
            <h5 class="mb-0 small text-uppercase py-1">?? Modify Tracker Architecture</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label small fw-bold">Start Period Date</label>
                    <input type="date" class="form-control" name="StartPeriodDate" value="@Model.StartPeriodDate.ToString("yyyy-MM-dd")" required />
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold">Cycle Days Interval Boundary (20-45)</label>
                    <input type="number" class="form-control" name="CycleDays" value="@Model.CycleDays" min="20" max="45" required />
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold">Average Period Duration (1-9 Days)</label>
                    <input type="number" class="form-control" name="PeriodLasts" value="@Model.PeriodLasts" min="1" max="9" required />
                </div>
                <div class="mb-4">
                    <label class="form-label small fw-bold">When do PMS symptoms appear:</label>
                    <select class="form-select" name="PMSOption">
                        @if (Model.PMSOption == 0)
                        {
                            <option value="0" selected>Not applicable</option>
                            <option value="1">1-3 days before period</option>
                            <option value="2">4-7 days before period</option>
                            <option value="3">7-14 days before period</option>
                        }
                        else if (Model.PMSOption == 1)
                        {
                            <option value="0">Not applicable</option>
                            <option value="1" selected>1-3 days before period</option>
                            <option value="2">4-7 days before period</option>
                            <option value="3">7-14 days before period</option>
                        }
                        else if (Model.PMSOption == 2)
                        {
                            <option value="0">Not applicable</option>
                            <option value="1">1-3 days before period</option>
                            <option value="2" selected>4-7 days before period</option>
                            <option value="3">7-14 days before period</option>
                        }
                        else
                        {
                            <option value="0">Not applicable</option>
                            <option value="1">1-3 days before period</option>
                            <option value="2">4-7 days before period</option>
                            <option value="3" selected>7-14 days before period</option>
                        }
                    </select>
                </div>
                <div class="d-flex justify-content-between border-top pt-3">
                    <a asp-action="Index" class="btn btn-sm btn-outline-secondary px-3">Discard Changes</a>
                    <button type="submit" class="btn btn-sm btn-primary px-4 fw-bold">Save Configuration</button>
                </div>
            </form>
        </div>
    </div>
</div>
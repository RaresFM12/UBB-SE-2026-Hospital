@model UBB_SE_2026_923_2.Web.ViewModels.PeriodTrackerViewModel
@{
    ViewData["Title"] = "Period Tracker Dashboard";
}

<div class="container py-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4 pb-3 border-bottom">
        <div>
            <h1 class="h3 mb-1 text-primary">Period Tracker Center</h1>
            <p class="text-muted mb-0">Configure the cycle, review the current phase, manage notes, and buy recommended items from one place.</p>
        </div>
    </div>

    <!-- Cycle Overview Top Section -->
    <div class="row mb-5">
        <div class="col-12">
            <partial name="CycleOverview" model="Model" />
        </div>
    </div>

    <div class="row g-4 align-items-stretch">
        <div class="col-lg-6">
            <partial name="CycleConfiguration" model="Model" />
        </div>

        <div class="col-lg-6">
            <partial name="DailyNotes" model="Model" />
        </div>
    </div>

    <partial name="RecommendedItems" model="Model" />
</div>
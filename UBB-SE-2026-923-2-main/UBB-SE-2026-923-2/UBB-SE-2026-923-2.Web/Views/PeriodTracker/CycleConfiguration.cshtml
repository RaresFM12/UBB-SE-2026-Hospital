@model UBB_SE_2026_923_2.Web.ViewModels.PeriodTrackerViewModel

<div class="card shadow-sm border-0 h-100">
    <div class="card-header bg-dark text-white fw-semibold">Cycle configuration</div>
    <div class="card-body">
        <form asp-action="@((Model.HasPeriodTracker) ? "Edit" : "Create")" asp-controller="PeriodTracker" method="post" class="vstack gap-3">
            @Html.AntiForgeryToken()
            <div>
                <label class="form-label small fw-semibold">Start period date</label>
                <input type="date" class="form-control" name="StartPeriodDate" value="@Model.StartPeriodDate.ToString("yyyy-MM-dd")" required />
            </div>

            <div>
                <label class="form-label small fw-semibold">Cycle days</label>
                <input type="number" class="form-control" name="CycleDays" value="@Model.CycleDays" min="20" max="45" required />
            </div>

            <div>
                <label class="form-label small fw-semibold">Period lasts</label>
                <input type="number" class="form-control" name="PeriodLasts" value="@Model.PeriodLasts" min="1" max="9" required />
            </div>

            <div>
                <label class="form-label small fw-semibold">PMS symptoms appear</label>
                <select class="form-select" name="PMSOption">
                    <option value="0" selected="@(Model.PMSOption == 0)">Not applicable</option>
                    <option value="1" selected="@(Model.PMSOption == 1)">1-3 days before period</option>
                    <option value="2" selected="@(Model.PMSOption == 2)">4-7 days before period</option>
                    <option value="3" selected="@(Model.PMSOption == 3)">7-14 days before period</option>
                </select>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">Save cycle</button>
            </div>
        </form>
    </div>
</div>
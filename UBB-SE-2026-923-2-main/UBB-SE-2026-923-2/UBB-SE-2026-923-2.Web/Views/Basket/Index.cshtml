@model BasketViewModel
@{
    ViewData["Title"] = "Basket";
}

<div class="mb-4">
    <h2>Basket</h2>
</div>

@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}
@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="row g-4">
    <div class="col-lg-8">
        @if (!Model.Items.Any())
        {
            <div class="alert alert-info">Your basket is empty.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Medicine</th>
                            <th>Producer</th>
                            <th>Discount</th>
                            <th>Quantity</th>
                            <th>Price</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>
                                    <strong>@item.ItemName</strong>
                                </td>
                                <td>@item.ItemProducer</td>
                                <td>
                                    <span class="text-muted">@item.ItemDiscountString</span>
                                    <span class="text-muted ms-1">@item.ItemUserDiscountString</span>
                                </td>
                                <td style="max-width: 120px;">
                                    <form asp-action="UpdateQuantity" method="post" class="quantity-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="ItemId" value="@item.ItemId" />
                                        <input class="form-control quantity-input" type="number" min="0" name="Quantity" value="@item.ItemQuantityInBasket" />
                                    </form>
                                </td>
                                <td>
                                    <div class="text-muted text-decoration-line-through">@item.FinalPriceBeforeDiscount.ToString("F2") RON</div>
                                    <strong>@item.FinalPriceAfterDiscount.ToString("F2") RON</strong>
                                </td>
                                <td class="text-end">
                                    <form asp-action="Remove" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="itemId" value="@item.ItemId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">Prescription</h5>
                <p class="text-muted small">If you have a valid prescription on your name, you can automatically put in your medicine.</p>
                <form asp-action="ApplyPrescription" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label asp-for="PrescriptionId" class="form-label">Prescription ID</label>
                        <input asp-for="PrescriptionId" class="form-control" placeholder="Enter prescription ID" />
                    </div>
                    <button type="submit" class="btn btn-outline-primary">Add Products</button>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <h5 class="card-title">Total</h5>
                <div class="text-muted text-decoration-line-through">@Model.TotalBeforeDiscount.ToString("F2") RON</div>
                <div class="display-6">@Model.TotalAfterDiscount.ToString("F2") RON</div>
                <a asp-controller="Orders" asp-action="Create" class="btn btn-primary mt-3 @(Model.Items.Any() ? string.Empty : "disabled")">Checkout</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.quantity-input').forEach(function (input) {
            input.addEventListener('change', function () {
                this.closest('.quantity-form').submit();
            });
        });
    </script>
}

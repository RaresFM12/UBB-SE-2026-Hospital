@model UBB_SE_2026_923_2.Models.Shift
@{
    ViewData["Title"] = "Edit Shift";
}

<h2>Edit Shift Status</h2>

<div class="alert alert-info mt-3">
    To change the times or location of a shift, please cancel this shift and schedule a new one.
    You can update the status below.
</div>

<div class="card p-4">
    <p><strong>Current Status:</strong> @Model.Status</p>

    @if (Model.Status == UBB_SE_2026_923_2.Models.ShiftStatus.SCHEDULED)
    {
        <form asp-action="Activate" asp-route-shiftId="@Model.Id" method="post" class="d-inline">
            <button type="submit" class="btn btn-success">Activate Shift</button>
        </form>
    }
    @if (Model.Status != UBB_SE_2026_923_2.Models.ShiftStatus.CANCELLED)
    {
        <form asp-action="Cancel" asp-route-shiftId="@Model.Id" method="post" class="d-inline">
            <button type="submit" class="btn btn-danger">Cancel Shift</button>
        </form>
    }

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>
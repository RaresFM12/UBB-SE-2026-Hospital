<Page
    x:Class="UBB_SE_2026_923_2.Views.ProductsCatalogue.ProductDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UBB_SE_2026_923_2.Views.ProductsCatalogue"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:UBB_SE_2026_923_2.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:StockLevelToColorConverter x:Key="StockColorConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Button Content="&#8592; Back"
                Click="OnBackClick"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="16"
                Background="Transparent"
                Foreground="{StaticResource AppAccentBrush}"
                FontSize="16"
                Canvas.ZIndex="1"/>

        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Center"
              MaxWidth="900"
              Padding="10">

            <Border Background="{StaticResource AppSurfaceBrush}"
                    BorderBrush="{StaticResource AppAccentBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="35">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Image x:Name="ProductImage"
                               Width="250"
                               Height="250"
                               Stretch="UniformToFill"
                               ImageFailed="OnProductImageFailed"/>

                        <StackPanel Grid.Column="1" Spacing="10">

                            <TextBlock x:Name="ProductName"
                                       Text="{Binding ProductName}"
                                       FontSize="26"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource AppAccentBrush}"/>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock x:Name="FinalPrice"
                                           Text="{Binding FinalPriceDisplay}"
                                           FontWeight="Bold"
                                           FontSize="18"
                                           Foreground="{StaticResource AppAccentBrush}"/>

                                <TextBlock x:Name="OldPrice"
                                           Text="{Binding OldPriceDisplay}"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"
                                           TextDecorations="Strikethrough"/>

                                <TextBlock x:Name="Discount"
                                           Text="{Binding DiscountDisplay}"
                                           Foreground="{StaticResource AppErrorBrush}"/>
                            </StackPanel>

                            <TextBlock Text="{Binding StockText}" 
                                       Foreground="{Binding CurrentStockLevel, Converter={StaticResource StockColorConverter}}" />

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBox x:Name="QuantityBox"
                                         Width="80"
                                         PlaceholderText="Qty"
                                         IsEnabled="{Binding IsQuantityBoxEnabled}"/>

                                <Button x:Name="AddToCartButton"
                                        Content="Add to Basket"
                                        Click="OnAddToBasket"
                                        IsEnabled="{Binding IsAddToCartEnabled}"/>
                            </StackPanel>

                            <Button x:Name="StockAlertButton"
                                    Content="{Binding StockAlertButtonText}"
                                    Click="OnToggleStockAlert"
                                    Background="#FF9800"
                                    Foreground="White"
                                    Visibility="{Binding IsStockAlertButtonVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                            </Button>

                            <TextBlock x:Name="ErrorText"
                                       Text="{Binding ErrorText}"
                                       Foreground="{StaticResource AppErrorBrush}"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="1"
                                Margin="0,30,0,0"
                                Spacing="10"
                                Background="{StaticResource AppBackgroundBrush}"
                                BorderBrush="{StaticResource AppAccentBrush}"
                                BorderThickness="1"
                                Padding="20"
                                CornerRadius="10">

                        <TextBlock Text="Description"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AppAccentBrush}"/>

                        <TextBlock x:Name="DescriptionText"
                                   Text="{Binding DescriptionText}"
                                   Foreground="{StaticResource AppTextPrimaryBrush}"
                                   TextWrapping="Wrap"/>

                        <TextBlock>
                            <Run Text="Label: " FontWeight="Bold" Foreground="{StaticResource AppAccentBrush}"/>
                            <Run x:Name="LabelText"
                                 Text="{Binding LabelText}"
                                 Foreground="{StaticResource AppTextPrimaryBrush}"/>
                        </TextBlock>

                        <TextBlock>
                            <Run Text="Producer: " FontWeight="Bold" Foreground="{StaticResource AppAccentBrush}"/>
                            <Run x:Name="ProducerText"
                                 Text="{Binding ProducerText}"
                                 Foreground="{StaticResource AppTextPrimaryBrush}"/>
                        </TextBlock>

                        <TextBlock>
                            <Run Text="Active substances: " FontWeight="Bold" Foreground="{StaticResource AppAccentBrush}"/>
                            <Run x:Name="SubstancesText"
                                 Text="{Binding SubstancesText}"
                                 Foreground="{StaticResource AppTextPrimaryBrush}"/>
                        </TextBlock>

                        <TextBlock>
                            <Run Text="Category: " FontWeight="Bold" Foreground="{StaticResource AppAccentBrush}"/>
                            <Run x:Name="CategoryText"
                                 Text="{Binding CategoryText}"
                                 Foreground="{StaticResource AppTextPrimaryBrush}"/>
                        </TextBlock>

                        <TextBlock>
                            <Run Text="Number of pills: " FontWeight="Bold" Foreground="{StaticResource AppAccentBrush}"/>
                            <Run x:Name="PillsText"
                                 Text="{Binding PillsText}"
                                 Foreground="{StaticResource AppTextPrimaryBrush}"/>
                        </TextBlock>

                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>

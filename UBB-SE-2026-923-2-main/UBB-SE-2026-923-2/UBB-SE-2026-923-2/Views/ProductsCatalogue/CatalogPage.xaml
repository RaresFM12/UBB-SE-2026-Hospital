<Page
    x:Name="RootPage"
    x:Class="UBB_SE_2026_923_2.Views.ProductsCatalogue.CatalogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UBB_SE_2026_923_2.Views.ProductsCatalogue"
    xmlns:converters="using:UBB_SE_2026_923_2.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid Padding="20" Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" 
                Background="{StaticResource AppSurfaceBrush}" 
                BorderBrush="{StaticResource AppAccentBrush}" 
                BorderThickness="1" 
                CornerRadius="10" 
                Padding="10" 
                Margin="0,0,15,0">
            <ScrollViewer>
                <StackPanel Spacing="12">
                    <TextBlock Text="Sort By" FontWeight="Bold" Margin="0,10,0,0" Foreground="{StaticResource AppAccentBrush}"/>
                    <ComboBox ItemsSource="{Binding SortOptions}" 
                              SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}" 
                              HorizontalAlignment="Stretch"/>

                    <ComboBox ItemsSource="{Binding SortDirections}" 
                              SelectedItem="{Binding SelectedSortDirection, Mode=TwoWay}" 
                              HorizontalAlignment="Stretch"/>

                    <TextBlock Text="Categories" FontWeight="Bold" Margin="0,10,0,0" Foreground="{StaticResource AppAccentBrush}"/>
                    <CheckBox Content="Pain Relief" IsChecked="{Binding FilterPainRelief, Mode=TwoWay}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                    <CheckBox Content="Wellness" IsChecked="{Binding FilterWellness, Mode=TwoWay}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                    <CheckBox Content="Cold and Flu" IsChecked="{Binding FilterColdAndFlu, Mode=TwoWay}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                    <CheckBox Content="Allergy" IsChecked="{Binding FilterAllergy, Mode=TwoWay}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                    <CheckBox Content="Digestion" IsChecked="{Binding FilterDigestion, Mode=TwoWay}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                    <CheckBox Content="Skincare" IsChecked="{Binding FilterSkincare, Mode=TwoWay}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                    <CheckBox Content="First Aid" IsChecked="{Binding FilterFirstAid, Mode=TwoWay}" Foreground="{StaticResource AppTextPrimaryBrush}"/>

                    <TextBlock Text="Price" FontWeight="Bold" Margin="0,10,0,0" Foreground="{StaticResource AppAccentBrush}"/>
                    <CheckBox Content="0 - 49 lei" IsChecked="{Binding FilterPrice0_49, Mode=TwoWay}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                    <CheckBox Content="50 - 99 lei" IsChecked="{Binding FilterPrice50_99, Mode=TwoWay}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                    <CheckBox Content="100 - 199 lei" IsChecked="{Binding FilterPrice100_199, Mode=TwoWay}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                    <CheckBox Content="200 - 499 lei" IsChecked="{Binding FilterPrice200_499, Mode=TwoWay}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                    <CheckBox Content="500+ lei" IsChecked="{Binding FilterPrice500Plus, Mode=TwoWay}" Foreground="{StaticResource AppTextPrimaryBrush}"/>

                    <TextBlock Text="Stock" FontWeight="Bold" Margin="0,10,0,0" Foreground="{StaticResource AppAccentBrush}"/>
                    <RadioButton Content="All" GroupName="StockGroup" IsChecked="{Binding IsStockAll, Mode=TwoWay}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                    <RadioButton Content="In Stock" GroupName="StockGroup" IsChecked="{Binding IsStockIn, Mode=TwoWay}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                    <RadioButton Content="Low Stock" GroupName="StockGroup" IsChecked="{Binding IsStockLow, Mode=TwoWay}" Foreground="{StaticResource AppTextPrimaryBrush}"/>

                    <TextBlock Text="Discount" FontWeight="Bold" Margin="0,10,0,0" Foreground="{StaticResource AppAccentBrush}"/>
                    <RadioButton Content="All" GroupName="DiscountGroup" IsChecked="{Binding IsDiscountAll, Mode=TwoWay}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                    <RadioButton Content="Discounted" GroupName="DiscountGroup" IsChecked="{Binding IsDiscountYes, Mode=TwoWay}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                    <RadioButton Content="Non-discounted" GroupName="DiscountGroup" IsChecked="{Binding IsDiscountNo, Mode=TwoWay}" Foreground="{StaticResource AppTextPrimaryBrush}"/>

                    <Button Content="Apply Filters" Command="{Binding ApplyFiltersCommand}" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="10,10,0,10" Spacing="10" Orientation="Horizontal">
                <TextBox Width="300" Text="{Binding SearchText, Mode=TwoWay}" PlaceholderText="Search products..."/>
                <Button Content="Search" Command="{Binding SearchCommand}"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1">
                <StackPanel>
                    <TextBlock Text="{Binding EmptyMessage}" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               Visibility="{Binding IsEmptyMessageVisible, Converter={StaticResource BoolToVisibilityConverter}}" Margin="0,20,0,0"/>

                    <ItemsControl ItemsSource="{Binding Products}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapGrid MaximumRowsOrColumns="5" Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Click="OnProductClicked" Background="Transparent" BorderThickness="0" Padding="0">
                                    <Border Width="220" Margin="10" Padding="10" CornerRadius="10" Background="{StaticResource AppSurfaceBrush}" BorderBrush="{StaticResource AppAccentBrush}" BorderThickness="1">
                                        <StackPanel Spacing="8">
                                            <Image Source="{Binding Image}" Height="120" Stretch="UniformToFill" ImageFailed="OnProductImageFailed"/>
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="{StaticResource AppTextPrimaryBrush}" TextWrapping="WrapWholeWords"/>

                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding FinalPriceDisplay}" Foreground="{StaticResource AppAccentBrush}" FontWeight="Bold"/>
                                                <TextBlock Text="{Binding OldPriceDisplay}" Foreground="{StaticResource AppTextSecondaryBrush}" TextDecorations="Strikethrough" Opacity="{Binding DiscountOpacity}"/>
                                                <TextBlock Text="{Binding DiscountDisplay}" Foreground="{StaticResource AppErrorBrush}" Opacity="{Binding DiscountOpacity}"/>
                                            </StackPanel>

                                            <TextBlock Text="{Binding StockText}" Foreground="{Binding StockColor}" FontSize="12"/>

                                            <Button Content="Add to Cart" 
                                                    Command="{Binding DataContext.AddToCartCommand, ElementName=RootPage}" 
                                                    CommandParameter="{Binding}" IsEnabled="{Binding CanAddToCart}" 
                                                    HorizontalAlignment="Stretch"/>
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,20,0,0">
                <Button Content="Previous" Command="{Binding PreviousPageCommand}" Background="Transparent" Foreground="{StaticResource AppAccentBrush}" BorderBrush="{StaticResource AppAccentBrush}" BorderThickness="1"/>
                <TextBlock Text="{Binding PageText}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource AppAccentBrush}"/>
                <Button Content="Next" Command="{Binding NextPageCommand}" Background="Transparent" Foreground="{StaticResource AppAccentBrush}" BorderBrush="{StaticResource AppAccentBrush}" BorderThickness="1"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>


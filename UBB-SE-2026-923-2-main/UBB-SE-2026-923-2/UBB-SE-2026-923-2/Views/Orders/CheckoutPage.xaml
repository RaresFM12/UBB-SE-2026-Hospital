<Page
    x:Class="UBB_SE_2026_923_2.Views.Orders.CheckoutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UBB_SE_2026_923_2.Views.Orders"
    xmlns:localModel="using:UBB_SE_2026_923_2.ViewModels.Orders"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20"
          ColumnDefinitions="*, Auto"
          Background="{StaticResource AppBackgroundBrush}">

        <ListView Grid.Row="0"
                  Grid.Column="0"
                  ItemsSource="{Binding BasketItems}">

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="localModel:BasketItemViewModel">
                    <Grid ColumnDefinitions="Auto, *, Auto">
                        <Image Grid.Row="0"
                               Grid.Column="0"
                               Source="{x:Bind ItemThumbnailImagePath, Mode=OneTime}"
                               Width="150"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="1"
                                   Text="{x:Bind ItemDescription, Mode=OneTime}"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   FontSize="15"
                                   Foreground="{StaticResource AppTextPrimaryBrush}"/>

                        <StackPanel Grid.Row="0"
                                    Grid.Column="2"
                                    Orientation="Vertical"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Spacing="10">

                            <TextBlock Text="{x:Bind ItemQuantityString, Mode=OneTime}"
                                       Foreground="{StaticResource AppTextPrimaryBrush}"/>
                            <TextBlock Text="{x:Bind ItemFinalDiscountedPriceString, Mode=OneTime}"
                                       FontWeight="Bold" Foreground="{StaticResource AppErrorBrush}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <ListView Grid.Row="0"
                  Grid.Column="1">

            <TextBlock Text="Total price:"
                       Foreground="{StaticResource AppTextPrimaryBrush}"/>
            <TextBlock Text="{Binding TotalPriceString}"
                       FontSize="30" Foreground="{StaticResource AppErrorBrush}" FontWeight="Bold"
                       Padding="15"/>

            <CalendarView Name="PickUpDateSelector"
                          SelectionMode="Single"
                          IsGroupLabelVisible="True"
                          Language="en"
                          CalendarIdentifier="GregorianCalendar"
                          Loaded="SetDefaultPickUpDate"
                          SelectedDatesChanged="CheckUnselectedDate"/>

            <StackPanel Orientation="Horizontal"
                        Padding="15"
                        Spacing="10">

                <Button Content="Place Order"
                        Click="PlaceOrder"/>
                <Button Content="Cancel"
                        Click="NavigateToBasket"
                        Background="Transparent"
                        Foreground="{StaticResource AppAccentBrush}"
                        BorderBrush="{StaticResource AppAccentBrush}"
                        BorderThickness="1"/>

            </StackPanel>
        </ListView>
    </Grid>
</Page>
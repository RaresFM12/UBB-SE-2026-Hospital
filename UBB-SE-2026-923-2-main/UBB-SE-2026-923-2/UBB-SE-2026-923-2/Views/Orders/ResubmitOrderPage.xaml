<Page
    x:Class="UBB_SE_2026_923_2.Views.Orders.ResubmitOrderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UBB_SE_2026_923_2.Views.Orders"
    xmlns:localModel="using:UBB_SE_2026_923_2.ViewModels.Orders"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20"
          ColumnDefinitions="*, 340"
          ColumnSpacing="20"
          Background="{StaticResource AppBackgroundBrush}">

        <Grid Grid.Column="0"
              RowDefinitions="Auto, *">
            <Grid Grid.Row="0"
                  ColumnDefinitions="2*, 2*, *, *"
                  Background="{StaticResource AppAccentBrush}"
                  Padding="12,10">
                <TextBlock Grid.Column="0" Text="Medicine" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Grid.Column="1" Text="Producer" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Grid.Column="2" Text="Quantity" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Grid.Column="3" Text="Final price" FontWeight="SemiBold" Foreground="White"/>
            </Grid>

            <ListView Grid.Row="1"
                      ItemsSource="{x:Bind viewModel.OrderItems}"
                      SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="localModel:ItemDetail">
                        <Grid ColumnDefinitions="2*, 2*, *, *"
                              Padding="12,10"
                              Background="{StaticResource AppSurfaceBrush}">
                            <TextBlock Grid.Column="0" Text="{x:Bind MedicineName}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{x:Bind Producer}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                            <TextBlock Grid.Column="2" Text="{x:Bind ItemQuantity}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                            <TextBlock Grid.Column="3" Text="{x:Bind ItemFinalPriceString}" FontWeight="SemiBold" Foreground="{StaticResource AppErrorBrush}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <Border Grid.Column="1"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppAccentBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">
            <StackPanel Spacing="14">
                <StackPanel>
                    <TextBlock Text="Total price"
                               FontSize="15"
                               Foreground="{StaticResource AppTextSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind viewModel.TotalPriceString}"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="{StaticResource AppErrorBrush}"/>
                </StackPanel>

                <TextBlock Text="Pick-up date"
                           FontSize="15"
                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                <CalendarView Name="PickUpDateSelector"
                              SelectionMode="Single"
                              IsGroupLabelVisible="True"
                              Language="en"
                              CalendarIdentifier="GregorianCalendar"
                              Loaded="SetDefaultPickUpDate"
                              SelectedDatesChanged="CheckUnselectedDate"/>

                <StackPanel Orientation="Horizontal"
                            Spacing="10">
                    <Button Content="Resubmit"
                            Click="ResubmitOrder"/>
                    <Button Content="Cancel"
                            Click="NavigateToOrderHistory"
                            Background="Transparent"
                            Foreground="{StaticResource AppAccentBrush}"
                            BorderBrush="{StaticResource AppAccentBrush}"
                            BorderThickness="1"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>

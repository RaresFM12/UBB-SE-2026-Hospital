<Page
    x:Class="UBB_SE_2026_923_2.Views.Orders.EditableOrderDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UBB_SE_2026_923_2.Views.Orders"
    xmlns:model="using:UBB_SE_2026_923_2.ViewModels.Orders"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="PageRoot">

    <Grid Padding="20"
          RowDefinitions="Auto, *"
          ColumnDefinitions="3*, *"
          Background="{StaticResource AppBackgroundBrush}">

        <Button Grid.Row="0"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Content="&#8592; Back"
                Click="OnBackClick"
                HorizontalAlignment="Left"
                Background="Transparent"
                Foreground="{StaticResource AppAccentBrush}"
                FontSize="16"
                Margin="0 0 0 10"/>

        <ListView Grid.Row="1"
                  Grid.Column="0"
                  ItemsSource="{x:Bind ViewModel.OrderItems}">

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="model:ItemDetail">
                    <Grid RowDefinitions="Auto, Auto"
                          ColumnDefinitions="Auto, *, Auto">

                        <Image Grid.Row="0"
                               Grid.RowSpan="2"
                               Grid.Column="0"
                               Source="{x:Bind ItemThumbnailImagePath, Mode=OneTime}"
                               Width="150"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                        <Grid Grid.Row="0"
                              Grid.Column="1"
                              Grid.ColumnDefinitions="*, Auto">

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="{x:Bind ItemDescription, Mode=OneTime}"
                                       VerticalAlignment="Center"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       Foreground="{StaticResource AppTextPrimaryBrush}"/>
                            <Button Grid.Row="0"
                                    Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Content="🗑"
                                    Background="Transparent"
                                    Foreground="{StaticResource AppErrorBrush}"
                                    Command="{Binding DataContext.RemoveItemCommand, ElementName=PageRoot}"
                                    CommandParameter="{Binding}"/>
                        </Grid>

                        <StackPanel Grid.Row="1"
                                    Grid.Column="1"
                                    Orientation="Vertical"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Spacing="10">

                            <TextBlock Text="{x:Bind ItemQuantityString, Mode=OneTime}"
                                       Foreground="{StaticResource AppTextPrimaryBrush}"/>
                            <TextBlock Text="{x:Bind ItemFinalPriceString, Mode=OneTime}"
                                       FontWeight="Bold" Foreground="{StaticResource AppErrorBrush}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <ListView Grid.Row="1"
                  Grid.Column="1">

            <TextBlock Text="Total price:"
                       FontSize="15"
                       Foreground="{StaticResource AppTextSecondaryBrush}"/>
            <TextBlock Text="{x:Bind ViewModel.TotalPriceString, Mode=OneWay}"
                       FontSize="30"
                       Foreground="{StaticResource AppErrorBrush}"
                       FontWeight="Bold"
                       Padding="15"/>

            <TextBlock Text="Order status:"
                       FontSize="15"
                       Foreground="{StaticResource AppTextSecondaryBrush}"/>
            <TextBlock Text="{x:Bind ViewModel.StatusString}"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="{StaticResource AppTextPrimaryBrush}"
                       Padding="15"/>

            <TextBlock Text="Pick-up date:"
                       FontSize="15"
                       Foreground="{StaticResource AppTextSecondaryBrush}"/>
            <TextBlock Text="{x:Bind ViewModel.PickUpDateString}"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="{StaticResource AppTextPrimaryBrush}"
                       Padding="15"/>

            <Button Content="Complete"
                    Click="CompleteOrder"/>
        </ListView>
    </Grid>
</Page>
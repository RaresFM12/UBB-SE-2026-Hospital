<Page
    x:Class="UBB_SE_2026_923_2.Views.Orders.NonEditableOrderDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:localModel="using:UBB_SE_2026_923_2.ViewModels.Orders"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20"
          RowDefinitions="Auto, Auto, *"
          Background="{StaticResource AppBackgroundBrush}">

        <Button Grid.Row="0"
                Content="&#8592; Back"
                Click="OnBackClick"
                HorizontalAlignment="Left"
                Background="Transparent"
                Foreground="{StaticResource AppAccentBrush}"
                FontSize="16"
                Margin="0,0,0,10"/>

        <Border Grid.Row="1"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppAccentBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16"
                Margin="0,0,0,16">
            <Grid ColumnDefinitions="2*, *, *, *, *"
                  RowDefinitions="Auto, Auto"
                  ColumnSpacing="20">

                <TextBlock Grid.Row="0" Grid.Column="0" Text="User email" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Bind ViewModel.UserEmail}" FontWeight="SemiBold" Foreground="{StaticResource AppTextPrimaryBrush}"/>

                <TextBlock Grid.Row="0" Grid.Column="1" Text="Pickup date" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.PickUpDateString}" FontWeight="SemiBold" Foreground="{StaticResource AppTextPrimaryBrush}"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="Expiration date" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                <TextBlock Grid.Row="1" Grid.Column="2" Text="{x:Bind ViewModel.ExpirationDateString}" FontWeight="SemiBold" Foreground="{StaticResource AppTextPrimaryBrush}"/>

                <TextBlock Grid.Row="0" Grid.Column="3" Text="Status" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                <TextBlock Grid.Row="1" Grid.Column="3" Text="{x:Bind ViewModel.StatusString}" FontWeight="SemiBold" Foreground="{StaticResource AppTextPrimaryBrush}"/>

                <TextBlock Grid.Row="0" Grid.Column="4" Text="Total price" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                <TextBlock Grid.Row="1" Grid.Column="4" Text="{x:Bind ViewModel.TotalPriceString}" FontWeight="SemiBold" Foreground="{StaticResource AppErrorBrush}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2"
              RowDefinitions="Auto, *">
            <Grid Grid.Row="0"
                  ColumnDefinitions="2*, 2*, *, *"
                  Background="{StaticResource AppAccentBrush}"
                  Padding="12,10">
                <TextBlock Grid.Column="0" Text="Medicine" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Grid.Column="1" Text="Producer" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Grid.Column="2" Text="Quantity" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Grid.Column="3" Text="Final price" FontWeight="SemiBold" Foreground="White"/>
            </Grid>

            <ListView Grid.Row="1"
                      ItemsSource="{x:Bind ViewModel.OrderItems}"
                      SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="localModel:ItemDetail">
                        <Grid ColumnDefinitions="2*, 2*, *, *"
                              Padding="12,10"
                              Background="{StaticResource AppSurfaceBrush}">
                            <TextBlock Grid.Column="0" Text="{x:Bind MedicineName}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{x:Bind Producer}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                            <TextBlock Grid.Column="2" Text="{x:Bind ItemQuantity}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                            <TextBlock Grid.Column="3" Text="{x:Bind ItemFinalPriceString}" FontWeight="SemiBold" Foreground="{StaticResource AppErrorBrush}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>

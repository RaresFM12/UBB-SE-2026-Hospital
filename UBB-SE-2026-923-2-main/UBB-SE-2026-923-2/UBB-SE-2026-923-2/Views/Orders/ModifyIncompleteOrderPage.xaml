<Page
    x:Class="UBB_SE_2026_923_2.Views.Orders.ModifyIncompleteOrderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:model="using:UBB_SE_2026_923_2.ViewModels.Orders"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="PageRoot">

    <Grid Padding="20"
          ColumnDefinitions="*, 340"
          ColumnSpacing="20"
          Background="{StaticResource AppBackgroundBrush}">

        <Grid Grid.Column="0"
              RowDefinitions="Auto, *">
            <Grid Grid.Row="0"
                  ColumnDefinitions="2*, 2*, *, *, Auto"
                  Background="{StaticResource AppAccentBrush}"
                  Padding="12,10">
                <TextBlock Grid.Column="0" Text="Medicine" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Grid.Column="1" Text="Producer" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Grid.Column="2" Text="Quantity" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Grid.Column="3" Text="Final price" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Grid.Column="4" Text="Remove" FontWeight="SemiBold" Foreground="White"/>
            </Grid>

            <ListView Grid.Row="1"
                      ItemsSource="{x:Bind ViewModel.OrderItems}"
                      SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="model:ItemDetail">
                        <Grid ColumnDefinitions="2*, 2*, *, *, Auto"
                              Padding="12,10"
                              Background="{StaticResource AppSurfaceBrush}">
                            <TextBlock Grid.Column="0" Text="{x:Bind MedicineName}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                            <TextBlock Grid.Column="1" Text="{x:Bind Producer}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                            <NumberBox Grid.Column="2"
                                       Value="{x:Bind ItemQuantityValue, Mode=TwoWay}"
                                       Minimum="0"
                                       SmallChange="1"
                                       LargeChange="1"
                                       SpinButtonPlacementMode="Inline"
                                       AcceptsExpression="False"
                                       ValidationMode="InvalidInputOverwritten"/>
                            <TextBlock Grid.Column="3" Text="{x:Bind ItemFinalPriceString, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource AppErrorBrush}"/>
                            <Button Grid.Column="4"
                                    Content="Delete"
                                    Background="Transparent"
                                    Foreground="{StaticResource AppErrorBrush}"
                                    BorderBrush="{StaticResource AppErrorBrush}"
                                    BorderThickness="1"
                                    Command="{Binding DataContext.RemoveItemCommand, ElementName=PageRoot}"
                                    CommandParameter="{Binding}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <Border Grid.Column="1"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppAccentBrush}"
                BorderThickness="1"
                CornerRadius="10"
                Padding="16">
            <StackPanel Spacing="14">
                <StackPanel>
                    <TextBlock Text="Total price"
                               FontSize="15"
                               Foreground="{StaticResource AppTextSecondaryBrush}"/>
                    <TextBlock Text="{x:Bind ViewModel.TotalPriceString, Mode=OneWay}"
                               FontSize="30"
                               Foreground="{StaticResource AppErrorBrush}"
                               FontWeight="Bold"/>
                </StackPanel>

                <TextBlock Text="Pick-up date"
                           FontSize="15"
                           Foreground="{StaticResource AppTextSecondaryBrush}"/>
                <CalendarView Name="PickUpDateSelector"
                              SelectionMode="Single"
                              IsGroupLabelVisible="True"
                              Language="en"
                              CalendarIdentifier="GregorianCalendar"
                              Loaded="SetPickUpDate"
                              SelectedDatesChanged="CheckUnselectedDate"/>

                <StackPanel Orientation="Horizontal"
                            Spacing="10">
                    <Button Content="Cancel"
                            Click="CancelChanges"
                            Background="Transparent"
                            Foreground="{StaticResource AppAccentBrush}"
                            BorderBrush="{StaticResource AppAccentBrush}"
                            BorderThickness="1"/>
                    <Button Content="Save changes"
                            Click="ModifyOrder"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>

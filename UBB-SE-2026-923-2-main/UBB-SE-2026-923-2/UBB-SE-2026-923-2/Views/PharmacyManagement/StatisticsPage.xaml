<Page
    x:Class="UBB_SE_2026_923_2.Views.PharmacyManagement.StatisticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UBB_SE_2026_923_2.Views.PharmacyManagement"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:UBB_SE_2026_923_2.Models"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollMode="Enabled"
                  HorizontalScrollMode="Enabled"
                  Background="{StaticResource AppBackgroundBrush}">

        <Grid Padding="20">

            <Button Content="Edit Page"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="10"
                    Click="GoToEditPageClick"/>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,50,0,10"
                        Spacing="10">

                <Button Content="Items" Click="OnItemsClick"/>
                <Button Content="Substances" Click="OnSubstancesClick"/>
            </StackPanel>

            <StackPanel x:Name="ItemsGrid"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,100,0,0"
                        Spacing="10">

                <TextBlock Text="Top 30 Most Ordered Items (Last Month)"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{StaticResource AppTextPrimaryBrush}"
                           HorizontalAlignment="Center"/>

                <Grid Width="600"
                      Height="400"
                      BorderBrush="{StaticResource AppAccentBrush}"
                      BorderThickness="1"
                      CornerRadius="8">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Background="{StaticResource AppSurfaceBrush}" Padding="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Item ID" Grid.Column="0" FontWeight="Bold" Foreground="{StaticResource AppTextPrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Item Name" Grid.Column="1" FontWeight="Bold" Foreground="{StaticResource AppTextPrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Orders" Grid.Column="2" FontWeight="Bold" Foreground="{StaticResource AppTextPrimaryBrush}" HorizontalAlignment="Center"/>
                    </Grid>

                    <ListView Grid.Row="1"
                              ItemsSource="{x:Bind TopItems}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="x:Object">
                                <Border BorderBrush="{StaticResource AppAccentBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="10">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Item1}" Foreground="{StaticResource AppTextPrimaryBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Item2}" Foreground="{StaticResource AppTextPrimaryBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Item3}" Foreground="{StaticResource AppTextPrimaryBrush}" HorizontalAlignment="Center"/>
                                    </Grid>

                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </StackPanel>

            <StackPanel x:Name="SubstancesGrid"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,100,0,0"
                        Spacing="10">

                <TextBlock Text="Top 30 Most Popular Substances (Last Month)"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{StaticResource AppTextPrimaryBrush}"
                           HorizontalAlignment="Center"/>

                <Grid Width="600"
                      Height="400"
                      BorderBrush="{StaticResource AppAccentBrush}"
                      BorderThickness="1"
                      CornerRadius="8">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Background="{StaticResource AppSurfaceBrush}" Padding="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Name" Grid.Column="0" FontWeight="Bold" Foreground="{StaticResource AppTextPrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Number of Orders" Grid.Column="1" FontWeight="Bold" Foreground="{StaticResource AppTextPrimaryBrush}" HorizontalAlignment="Center"/>
                    </Grid>

                    <ListView Grid.Row="1"
                              ItemsSource="{x:Bind TopSubstances}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="x:Object">
                                <Border BorderBrush="{StaticResource AppAccentBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="10">

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding Key}" Foreground="{StaticResource AppTextPrimaryBrush}" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="{StaticResource AppTextPrimaryBrush}" HorizontalAlignment="Center"/>
                                    </Grid>

                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>

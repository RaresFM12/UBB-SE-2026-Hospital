<Page
    x:Class="UBB_SE_2026_923_2.Views.PharmacyManagement.Notifications"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:viewModels="using:UBB_SE_2026_923_2.ViewModels.PharmacyManagement"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{StaticResource AppBackgroundBrush}" Padding="20">
        <ListView ItemsSource="{x:Bind ViewModel.Notifications}" Width="500" HorizontalAlignment="Center">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:NotificationViewModel">
                    <Border Background="{StaticResource AppSurfaceBrush}"
                            BorderBrush="{StaticResource AppAccentBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="20"
                            Margin="0,10,0,10">
                        <StackPanel Orientation="Vertical" Spacing="15">
                            <TextBlock Text="{x:Bind NotificationTitle}" 
                                       FontSize="20" 
                                       FontWeight="SemiBold" 
                                       Foreground="{StaticResource AppAccentBrush}" 
                                       VerticalAlignment="Top"/>
                            <TextBlock Text="{x:Bind NotificationBody}" 
                                       Foreground="{StaticResource AppTextPrimaryBrush}" 
                                       TextWrapping="Wrap"/>
                            <Button Content="{x:Bind NotificationButtonText}" 
                                    Click="OnNotificationButtonClicked" 
                                    HorizontalAlignment="Left" 
                                    Margin="0,10,0,0"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
<Page
    x:Class="UBB_SE_2026_923_2.Views.IncomingSwapRequestsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{StaticResource AppBackgroundBrush}" Padding="24">
        <Border Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppAccentBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Width="450">
            <StackPanel Spacing="10">
                <TextBlock Text="Incoming Swap Requests"
                           Foreground="{StaticResource AppAccentBrush}"
                           FontSize="24"
                           FontWeight="SemiBold"/>

                <TextBlock Text="Select doctor (test mode)"
                           Foreground="{StaticResource AppTextSecondaryBrush}"/>

                <ComboBox ItemsSource="{Binding Doctors}"
                          SelectedItem="{Binding SelectedDoctor, Mode=TwoWay}"
                          DisplayMemberPath="DisplayName"
                          PlaceholderText="Select doctor"
                          HorizontalAlignment="Stretch"/>

                <ListView ItemsSource="{Binding Requests}"
                          SelectedItem="{Binding SelectedRequest, Mode=TwoWay}"
                          MinHeight="260">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource AppAccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10"
                                    Margin="0,0,0,8"
                                    Background="{StaticResource AppBackgroundBrush}">
                                <TextBlock Text="{Binding DisplayText}"
                                           Foreground="{StaticResource AppTextPrimaryBrush}"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Refresh" Command="{Binding RefreshCommand}" Background="Transparent" Foreground="{StaticResource AppAccentBrush}" BorderBrush="{StaticResource AppAccentBrush}" BorderThickness="1"/>
                    <Button Content="Accept" Command="{Binding AcceptCommand}"/>
                    <Button Content="Reject" Command="{Binding RejectCommand}" Background="{StaticResource AppErrorBrush}" Foreground="White"/>
                </StackPanel>

                <InfoBar IsOpen="True"
                         IsClosable="False"
                         Severity="Informational"
                         Message="{Binding StatusMessage}" />
            </StackPanel>
        </Border>
    </Grid>
</Page>

<UserControl
    x:Class="UBB_SE_2026_923_2.Views.CreateShiftPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{StaticResource AppBackgroundBrush}" Padding="24">

        <Border Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppAccentBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="20"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Width="350">

            <StackPanel Spacing="15">
                <TextBlock Text="Programare Tură Nouă"
                           Foreground="{StaticResource AppAccentBrush}"
                           FontSize="24" 
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                <ComboBox x:Name="EmployeeComboBox"
                          Header="Personal medical"
                          PlaceholderText="Alege angajatul"
                          HorizontalAlignment="Stretch"/>

                <CalendarDatePicker x:Name="ShiftDatePicker"
                                    Header="Data calendaristică"
                                    HorizontalAlignment="Stretch"/>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TimePicker x:Name="StartTimePicker" Header="Start" 
                                Grid.Column="0" HorizontalAlignment="Stretch"/>

                    <TimePicker x:Name="EndTimePicker" Header="Final" 
                                Grid.Column="1" HorizontalAlignment="Stretch"/>
                </Grid>

                <Button Content="Confirmă Tura"
                        Click="SaveShift_Click"
                        HorizontalAlignment="Stretch"
                        Margin="0,10,0,0"/>

                <InfoBar x:Name="StatusInfoBar" IsOpen="False" IsClosable="True" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

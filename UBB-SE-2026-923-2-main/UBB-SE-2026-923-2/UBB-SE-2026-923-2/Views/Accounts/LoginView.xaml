<Page
    x:Class="UBB_SE_2026_923_2.Views.Accounts.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UBB_SE_2026_923_2.Views.Accounts"
    xmlns:converters="using:UBB_SE_2026_923_2.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Page.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Border Width="340"
                Padding="28"
                Background="{StaticResource AppBackgroundBrush}"
                CornerRadius="12"
                BorderBrush="{StaticResource AppAccentBrush}"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel Spacing="14">
                <TextBlock Text="Login"
                           FontSize="26"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AppAccentBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>

                <TextBox Header="Email"
                         PlaceholderText="Email"
                         Text="{Binding Email, Mode=TwoWay}"/>

                <PasswordBox x:Name="PasswordBox"
                             Header="Password"
                             PlaceholderText="Password"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <Border Background="#11FF0000"
                        Padding="10"
                        CornerRadius="6"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource AppErrorBrush}"/>
                </Border>

                <Button Content="Login"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Command="{Binding LoginCommand}"
                        Margin="0,4,0,0"/>

                <TextBlock HorizontalAlignment="Center">
                    <Run Text="Don't have an account?" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                    <Hyperlink Click="Register_Click">
                        <Run Foreground="{StaticResource AppAccentBrush}">Register</Run>
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Page>
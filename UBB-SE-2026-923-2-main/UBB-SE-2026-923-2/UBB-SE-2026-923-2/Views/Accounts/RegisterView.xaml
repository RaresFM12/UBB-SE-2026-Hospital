<Page
    x:Class="UBB_SE_2026_923_2.Views.Accounts.RegisterView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UBB_SE_2026_923_2.Views.Accounts"
    xmlns:converters="using:UBB_SE_2026_923_2.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Page.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Border Width="340"
                Padding="28"
                Background="{StaticResource AppBackgroundBrush}"
                CornerRadius="12"
                BorderBrush="{StaticResource AppAccentBrush}"
                BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel Spacing="14">
                <TextBlock Text="Register"
                           FontSize="26"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource AppAccentBrush}"
                           Margin="0,0,0,6"/>

                <TextBox Header="Email"
                         PlaceholderText="Email"
                         Text="{Binding Email, Mode=TwoWay}"/>

                <TextBox Header="Phone Number"
                         PlaceholderText="Phone number"
                         Text="{Binding PhoneNumber, Mode=TwoWay}"/>

                <TextBox Header="Username"
                         PlaceholderText="Username"
                         Text="{Binding Username, Mode=TwoWay}"/>

                <PasswordBox x:Name="PasswordBox"
                             Header="Password"
                             PlaceholderText="Password"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <PasswordBox x:Name="ConfirmPasswordBox"
                             Header="Confirm Password"
                             PlaceholderText="Confirm password"
                             PasswordChanged="ConfirmPasswordBox_PasswordChanged"/>

                <ComboBox Header="Role"
                          PlaceholderText="Select Role"
                          ItemsSource="{Binding RoleOptions}"
                          SelectedItem="{Binding SelectedRole, Mode=TwoWay}"
                          HorizontalAlignment="Stretch"/>

                <Border Background="#11FF0000"
                        Padding="10"
                        CornerRadius="6"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding ErrorMessage}"
                               Foreground="{StaticResource AppErrorBrush}"
                               TextWrapping="Wrap"/>
                </Border>

                <Button Content="Register"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Margin="0,4,0,0"
                        Command="{Binding RegisterCommand}"/>

                <TextBlock HorizontalAlignment="Center">
                    <Run Text="Already have an account?" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                    <Hyperlink Click="Login_Click">
                        <Run Foreground="{StaticResource AppAccentBrush}">Login</Run>
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Page>
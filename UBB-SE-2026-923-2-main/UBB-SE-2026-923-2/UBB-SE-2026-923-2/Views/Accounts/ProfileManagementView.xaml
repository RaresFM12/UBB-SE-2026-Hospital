<Page
    x:Class="UBB_SE_2026_923_2.Views.Accounts.ProfileManagementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UBB_SE_2026_923_2.Views.Accounts"
    xmlns:converters="using:UBB_SE_2026_923_2.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    </Page.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Border Padding="20"
                Background="{StaticResource AppSurfaceBrush}"
                CornerRadius="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel Spacing="12" Padding="20" MaxWidth="400">
                <TextBlock Text="My Profile"
                           FontSize="24"
                           Foreground="{StaticResource AppAccentBrush}"
                           FontWeight="Bold"/>

                <TextBlock Text="Email" Foreground="{StaticResource AppAccentBrush}"/>
                <TextBox Text="{Binding Email}" IsReadOnly="True"/>

                <TextBlock Text="Username" Foreground="{StaticResource AppAccentBrush}"/>
                <TextBox Text="{Binding Username, Mode=TwoWay}"/>

                <TextBlock Text="Phone Number" Foreground="{StaticResource AppAccentBrush}"/>
                <TextBox Text="{Binding PhoneNumber, Mode=TwoWay}"/>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Change Password" Click="OnChangePasswordClick"/>
                </StackPanel>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{StaticResource AppErrorBrush}"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button Content="Save Changes" Click="OnSaveClick"/>
                    <Button Content="Cancel" Click="OnCancelClick"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>

<Page
    x:Class="UBB_SE_2026_923_2.Views.SalaryPlaceholderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{StaticResource AppBackgroundBrush}" Padding="40">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="20"
                    MaxWidth="400">

            <TextBlock Text="Salary Computation"
                       Foreground="{StaticResource AppAccentBrush}"
                       FontSize="36"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <ComboBox Header="Select Staff Member"
                      ItemsSource="{Binding StaffList}"
                      SelectedItem="{Binding SelectedStaff, Mode=TwoWay}"
                      HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Foreground="{StaticResource AppTextPrimaryBrush}">
                            <Run Text="{Binding FirstName}"/> <Run Text="{Binding LastName}"/>
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <NumberBox Header="Month (1-12)"
                           Value="{Binding SelectedMonth, Mode=TwoWay}"
                           Minimum="1" Maximum="12"
                           SpinButtonPlacementMode="Compact"
                           Grid.Column="0" />

                <NumberBox Header="Year"
                           Value="{Binding SelectedYear, Mode=TwoWay}"
                           Minimum="2000" Maximum="2100"
                           SpinButtonPlacementMode="Compact"
                           Grid.Column="1" />
            </Grid>

            <Button Content="Compute Salary"
                    Command="{Binding ComputeSalaryCommand}"
                    HorizontalAlignment="Stretch"
                    Margin="0,10,0,0"/>

            <ProgressRing IsActive="{Binding IsLoading}" 
                          HorizontalAlignment="Center" 
                          Margin="0,10,0,0"/>

            <TextBlock Text="{Binding SalaryResult}"
                       Foreground="{StaticResource AppAccentBrush}"
                       FontSize="22"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap" />

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource AppErrorBrush}"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       TextWrapping="Wrap" />

        </StackPanel>
    </Grid>
</Page>


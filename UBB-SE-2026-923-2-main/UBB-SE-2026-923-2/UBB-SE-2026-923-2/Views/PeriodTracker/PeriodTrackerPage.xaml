<Page
    x:Class="UBB_SE_2026_923_2.Views.PeriodTracker.PeriodTrackerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:UBB_SE_2026_923_2.ViewModels.PeriodTracker"
    xmlns:converters="using:UBB_SE_2026_923_2.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollMode="Enabled"
                  HorizontalScrollMode="Enabled"
                  Width="Auto"
                  Height="Auto"
                  Background="{StaticResource AppBackgroundBrush}">

        <Grid RowSpacing="20" Padding="25" CanBeScrollAnchor="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal"
                        Spacing="15"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{x:Bind ViewModel.CalendarsVisibility, Mode=OneWay}">
                <Grid Padding="30" ColumnSpacing="30" CornerRadius="20" Opacity="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.ColumnSpan="3"
                               Padding="0 0 0 20"
                               Text="{x:Bind ViewModel.Calendars.CurrentMonth, Mode=OneWay}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontSize="30"
                               Foreground="{StaticResource AppTextPrimaryBrush}"
                               FontWeight="Bold"/>

                    <StackPanel Grid.Column="0"
                                Grid.Row="1"
                                CornerRadius="10"
                                Orientation="Vertical"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Spacing="5"
                                Padding="15 15 120 15"
                                Background="{StaticResource AppSurfaceBrush}"
                                BorderBrush="{StaticResource AppAccentBrush}"
                                BorderThickness="1">
                        <StackPanel Spacing="10" Orientation="Horizontal" VerticalAlignment="Top" Margin="0 0 0 30">
                            <SymbolIcon Symbol="Calendar" Foreground="{StaticResource AppAccentBrush}"/>
                            <TextBlock Text="Today" Foreground="{StaticResource AppTextSecondaryBrush}" FontWeight="Bold" VerticalAlignment="Top"/>
                        </StackPanel>
                        <TextBlock Foreground="{StaticResource AppTextPrimaryBrush}"
                                   Text="{x:Bind ViewModel.Calendars.LiterallyTodayString, Mode=OneWay}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   VerticalAlignment="Bottom"/>
                        <TextBlock Foreground="#E11D48"
                                   Text="{x:Bind ViewModel.Calendars.CurrentPhaseString, Mode=OneWay}"
                                   FontSize="12"
                                   VerticalAlignment="Bottom"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Grid.Row="1"
                                CornerRadius="10"
                                Orientation="Vertical"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Spacing="5"
                                Padding="15 15 120 15"
                                Background="{StaticResource AppSurfaceBrush}"
                                BorderBrush="{StaticResource AppAccentBrush}"
                                BorderThickness="1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0 0 0 30" Spacing="10">
                            <SymbolIcon Symbol="Favorite" Foreground="{StaticResource AppAccentBrush}"/>
                            <TextBlock Text="Next Period" Foreground="{StaticResource AppTextSecondaryBrush}" FontWeight="Bold" VerticalAlignment="Top"/>
                        </StackPanel>
                        <TextBlock Foreground="{StaticResource AppTextPrimaryBrush}"
                                   Text="{x:Bind ViewModel.Calendars.NextPeriodDateString, Mode=OneWay}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   VerticalAlignment="Bottom"/>
                        <TextBlock Foreground="#E11D48"
                                   Text="{x:Bind ViewModel.Calendars.NextPeriodDistanceString, Mode=OneWay}"
                                   FontSize="12"
                                   VerticalAlignment="Bottom"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Grid.Row="1"
                                CornerRadius="10"
                                Orientation="Vertical"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Spacing="5"
                                Padding="15 15 120 15"
                                Background="{StaticResource AppSurfaceBrush}"
                                BorderBrush="{StaticResource AppAccentBrush}"
                                BorderThickness="1">
                        <StackPanel Spacing="10" Orientation="Horizontal" VerticalAlignment="Top" Margin="0 0 0 30">
                            <SymbolIcon Symbol="Share" Foreground="{StaticResource AppAccentBrush}"/>
                            <TextBlock Text="Ovulation" Foreground="{StaticResource AppTextSecondaryBrush}" FontWeight="Bold" VerticalAlignment="Top"/>
                        </StackPanel>
                        <TextBlock Foreground="{StaticResource AppTextPrimaryBrush}"
                                   Text="{x:Bind ViewModel.Calendars.CurrentOvulationDateString, Mode=OneWay}"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   VerticalAlignment="Bottom"/>
                        <TextBlock Foreground="#D97706"
                                   Text="{x:Bind ViewModel.Calendars.PastOvulationString, Mode=OneWay}"
                                   FontSize="12"
                                   VerticalAlignment="Bottom"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Spacing="10"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Visibility="{x:Bind ViewModel.CalendarsVisibility, Mode=OneWay}">
                <Button Command="{x:Bind ViewModel.PreviousCycleCommand}"
                        Content="&lt;"
                        Width="40"
                        Height="40"
                        FontSize="25"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="0 0 0 10"/>

                <StackPanel Orientation="Vertical"
                            Spacing="20"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            MinWidth="500">
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <Rectangle Width="12" Height="12" Fill="#E11D48" RadiusX="2" RadiusY="2"/>
                        <TextBlock FontSize="16"
                                   Foreground="#E11D48"
                                   FontWeight="Bold"
                                   Text="{x:Bind ViewModel.Calendars.PeriodInterval, Mode=OneWay}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <Rectangle Width="12" Height="12" Fill="#16A34A" RadiusX="2" RadiusY="2"/>
                        <TextBlock FontSize="16"
                                   Foreground="#16A34A"
                                   Text="{x:Bind ViewModel.Calendars.LowFertilityInterval, Mode=OneWay}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <Rectangle Width="12" Height="12" Fill="#0891B2" RadiusX="2" RadiusY="2"/>
                        <TextBlock FontSize="16"
                                   Foreground="#0891B2"
                                   Text="{x:Bind ViewModel.Calendars.OvulationInterval, Mode=OneWay}"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                        <Rectangle Width="12" Height="12" Fill="#EA580C" RadiusX="2" RadiusY="2"/>
                        <TextBlock FontSize="16"
                                   Foreground="#EA580C"
                                   Text="{x:Bind ViewModel.Calendars.PremenstrualSyndromeInterval, Mode=OneWay}"/>
                    </StackPanel>
                </StackPanel>

                <Button Command="{x:Bind ViewModel.NextCycleCommand}"
                        Content="&gt;"
                        Width="40"
                        Height="40"
                        FontSize="25"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="0 0 0 10"/>
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        Spacing="30"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                <DatePicker Date="{x:Bind ViewModel.StartPeriodDate, Mode=TwoWay}"
                            Header="Start Date of Last Period"
                            VerticalAlignment="Center"
                            DayFormat="{}{day.integer} ({dayofweek.abbreviated})"/>

                <StackPanel Orientation="Vertical" Spacing="4" Width="160">
                    <TextBlock Text="How much did your last period last:"
                               Foreground="{StaticResource AppTextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                    <TextBox Text="{x:Bind ViewModel.PeriodLastsInputText, Mode=TwoWay}"
                             PlaceholderText="1 – 9"
                             Foreground="{StaticResource AppTextPrimaryBrush}"
                             Width="160"/>
                </StackPanel>

                <StackPanel Orientation="Vertical" Spacing="4" Width="160">
                    <TextBlock Text="How much does your average cycle last:"
                               Foreground="{StaticResource AppTextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                    <TextBox Text="{x:Bind ViewModel.CycleDaysInputText, Mode=TwoWay}"
                             PlaceholderText="20 – 45"
                             Foreground="{StaticResource AppTextPrimaryBrush}"
                             Width="160"/>
                </StackPanel>

                <StackPanel Orientation="Vertical"
                            Spacing="20"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <RadioButtons Header="When do PMS symptoms appear:"
                                  SelectedIndex="{x:Bind ViewModel.PremenstrualSyndromeOptionInput, Mode=TwoWay}">
                        <RadioButton Content="Not applicable"/>
                        <RadioButton Content="1-3 days before period"/>
                        <RadioButton Content="4-7 days before period"/>
                        <RadioButton Content="7-14 days before period"/>
                    </RadioButtons>
                </StackPanel>

            </StackPanel>

            <StackPanel Grid.Row="3"
                        Orientation="Vertical"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <Button Command="{x:Bind ViewModel.CalculateCommand}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="30,10"
                        FontSize="16"
                        Content="CALCULATE"/>
                <TextBlock Text="{x:Bind ViewModel.ValidationErrorMessage, Mode=OneWay}"
                           Foreground="{StaticResource AppErrorBrush}"
                           HorizontalAlignment="Center"
                           Visibility="{x:Bind ViewModel.HasValidationError, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>

            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">
                <GridView SelectionMode="None"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          ItemsSource="{x:Bind ViewModel.Notes, Mode=OneWay}">

                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="Margin" Value="10"/>
                            <Setter Property="MaxWidth" Value="250"/>
                        </Style>
                    </GridView.ItemContainerStyle>

                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid MaximumRowsOrColumns="4" Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>

                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:NoteViewModel">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Width="220"
                                        Height="100">
                                <CheckBox IsChecked="{x:Bind NoteIsDone, Mode=TwoWay}"
                                          VerticalAlignment="Top"
                                          HorizontalAlignment="Right"
                                          MaxWidth="20"
                                          Margin="0 -5 -98 0"/>

                                <TextBox Text="{x:Bind NoteBody, Mode=TwoWay}"
                                         FontStyle="{x:Bind NoteBodyFontStyle, Mode=OneWay}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         Width="150"
                                         Height="100"
                                         MaxLength="100"/>

                                <Button Command="{x:Bind DeleteNoteCommand}"
                                        Content="x"
                                        VerticalAlignment="Top"
                                        Background="Transparent"
                                        Foreground="{StaticResource AppTextSecondaryBrush}"
                                        Margin="-8 0 0 0"
                                        Width="30"/>
                            </StackPanel>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>

                <Button Command="{x:Bind ViewModel.AddNoteCommand}"
                        Visibility="{x:Bind ViewModel.AddNoteVisibility, Mode=OneWay}"
                        Margin="0 10 0 0"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Left"
                        MaxWidth="50"
                        MaxHeight="50"
                        Content="+"/>
            </StackPanel>

            <FlipView Grid.Row="5"
                      SelectedIndex="0"
                      Visibility="{x:Bind ViewModel.ShopVisibility, Mode=OneWay}"
                      HorizontalAlignment="Center"
                      ItemsSource="{x:Bind ViewModel.ItemsLists, Mode=OneWay}"
                      Height="180"
                      Width="800">
                <FlipView.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:ItemListViewModel">
                        <ItemsControl ItemsSource="{x:Bind Items}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:ItemViewModel">
                                    <Grid Width="180" Margin="10 0 10 0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                            <RowDefinition Height="40"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <Image Width="70"
                                               Source="{x:Bind ImagePath}"
                                               Grid.Row="0"
                                               Grid.RowSpan="3"
                                               Grid.Column="0"/>

                                        <TextBlock Text="{x:Bind Name}"
                                                   Grid.Row="0"
                                                   Grid.Column="1"
                                                   HorizontalAlignment="Left"
                                                   VerticalAlignment="Top"
                                                   Foreground="{StaticResource AppTextPrimaryBrush}"
                                                   TextWrapping="WrapWholeWords"/>

                                        <TextBlock TextDecorations="Strikethrough"
                                                   Foreground="{x:Bind PriceColor}"
                                                   Text="{x:Bind PriceDiscountedString}"
                                                   Grid.Row="1"
                                                   Grid.Column="1"
                                                   Margin="0 0 0 -10"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Bottom"/>

                                        <TextBlock Foreground="{x:Bind FinalPriceColor}"
                                                   Text="{x:Bind PriceString}"
                                                   Grid.Row="2"
                                                   Grid.Column="1"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Bottom"
                                                   Padding="0 0 0 10"/>

                                        <Button Width="150"
                                                Grid.Column="0"
                                                Grid.Row="3"
                                                Grid.ColumnSpan="2"
                                                Content="Add to basket"
                                                Command="{x:Bind AddToBasketCommand}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DataTemplate>
                </FlipView.ItemTemplate>
            </FlipView>
        </Grid>
    </ScrollViewer>
</Page>
<Page
    x:Class="UBB_SE_2026_923_2.Views.Admin.AdminShiftView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:UBB_SE_2026_923_2.Models"
    mc:Ignorable="d">

    <Grid Background="{StaticResource AppBackgroundBrush}" Padding="24" ColumnSpacing="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppAccentBrush}" BorderThickness="1"
                CornerRadius="12" Padding="20" VerticalAlignment="Top">

            <StackPanel Spacing="15">
                <TextBlock Text="Create New Shift" Foreground="{StaticResource AppAccentBrush}" 
                           FontSize="24" FontWeight="SemiBold" Margin="0,0,0,10"/>

                <ComboBox x:Name="LocationComboBox" 
                          Header="Location / Department" 
                          PlaceholderText="Choose Location" 
                          HorizontalAlignment="Stretch"
                          SelectionChanged="LocationComboBox_SelectionChanged">
                    <x:String>ER</x:String>
                    <x:String>Ward A</x:String>
                    <x:String>Ward B</x:String>
                    <x:String>Cardiology</x:String>
                    <x:String>Surgery</x:String>
                    <x:String>Neurology</x:String>
                    <x:String>Pediatry</x:String>
                    <x:String>Oncology</x:String>
                    <x:String>Pharmacy</x:String>
                </ComboBox>

                <ComboBox x:Name="SpecializationCertificationComboBox"
                          Header="Specialization / Certification"
                          PlaceholderText="Choose Specialization or Certification"
                          HorizontalAlignment="Stretch"
                          ItemsSource="{x:Bind ViewModel.SpecializationsAndCertifications, Mode=OneWay}"
                          SelectionChanged="SpecializationCertificationComboBox_SelectionChanged" />

                <ComboBox x:Name="StaffComboBox" 
                        Header="Select the employee" 
                        PlaceholderText="Select an employee for the shift"
                        HorizontalAlignment="Stretch"
                        ItemsSource="{x:Bind ViewModel.AvailableStaff, Mode=OneWay}"
                        DisplayMemberPath="FirstName" />

                <TextBlock Text="Qualified found staff:" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="12" Margin="0,5,0,-10"/>
                <ListView ItemsSource="{x:Bind ViewModel.AvailableStaff, Mode=OneWay}"
                          MaxHeight="120" BorderThickness="1" BorderBrush="{StaticResource AppAccentBrush}"
                          CornerRadius="8" Background="{StaticResource AppBackgroundBrush}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:IStaff">
                            <StackPanel Orientation="Horizontal" Spacing="10" Padding="5">
                                <SymbolIcon Symbol="ContactInfo" Foreground="{StaticResource AppAccentBrush}"/>
                                <TextBlock Text="{x:Bind FirstName}" Foreground="{StaticResource AppTextPrimaryBrush}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind LastName}" Foreground="{StaticResource AppTextPrimaryBrush}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <CalendarDatePicker x:Name="ShiftDatePicker" 
                                    Header="Shift Date" 
                                    HorizontalAlignment="Stretch"/>

                <TimePicker x:Name="StartTimePicker" Header="Starting Hour" HorizontalAlignment="Stretch"/>
                <TimePicker x:Name="EndTimePicker" Header="Ending Hour" HorizontalAlignment="Stretch"/>

                <Button Content="Schedule the Shift" 
                        Click="CreateShift_Click" 
                        HorizontalAlignment="Stretch" Margin="0,10,0,0"/>

                <InfoBar x:Name="StatusInfoBar" IsOpen="False" IsClosable="True" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Background="{StaticResource AppSurfaceBrush}"
              BorderBrush="{StaticResource AppAccentBrush}" BorderThickness="1"
              CornerRadius="12" Padding="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Vertical" Spacing="20" Margin="0,0,0,20" VerticalAlignment="Center">
                <TextBlock Text="Today's Shifts" Foreground="{StaticResource AppAccentBrush}" FontSize="24" FontWeight="SemiBold"/>

                <Button Content="Back to Shift Management"
                        Click="OpenSchedule_Click" 
                        Background="#0288D1"/>
            </StackPanel>

            <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Shifts, Mode=OneWay}" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Shift">
                        <Grid Padding="15" Margin="0,0,0,10" Background="{StaticResource AppBackgroundBrush}" CornerRadius="8" BorderBrush="{StaticResource AppAccentBrush}" BorderThickness="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Spacing="5">
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="{x:Bind AppointedStaff.FirstName}" Foreground="{StaticResource AppTextPrimaryBrush}" FontWeight="Bold" FontSize="16"/>
                                    <TextBlock Text="{x:Bind AppointedStaff.LastName}" Foreground="{StaticResource AppTextPrimaryBrush}" FontWeight="Bold" FontSize="16"/>
                                </StackPanel>
                                <TextBlock Text="{x:Bind Location}" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <TextBlock Text="{x:Bind StartTime}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                                    <TextBlock Text="-" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                                    <TextBlock Text="{x:Bind EndTime}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                                </StackPanel>
                                <TextBlock Text="{x:Bind Status}" Foreground="#15803D" FontWeight="SemiBold"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" Margin="0,10,0,0">
                                <Button Content="Set Active" Click="SetActive_Click" Tag="{x:Bind Id}" Background="#16A34A"/>
                                <Button Content="Cancel" Click="CancelShift_Click" Tag="{x:Bind Id}" Background="#DC2626"/>
                                <Button Content="Auto-Reassign" Click="AutoReassign_Click" Tag="{x:Bind}" Background="#0288D1"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>

<Page
    x:Class="UBB_SE_2026_923_2.Views.Admin.BookAppointmentPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{StaticResource AppBackgroundBrush}" Padding="24">
        <Border Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppAccentBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="24"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Width="520">
            <StackPanel Spacing="16">
                <TextBlock Text="Book appointment"
                           Foreground="{StaticResource AppAccentBrush}"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8"/>

                <TextBox x:Name="PatientIdTextBox"
                         Header="Patient id"
                         PlaceholderText="123 or PAT-123"/>

                <ComboBox x:Name="DoctorComboBox"
                          Header="Doctor"
                          PlaceholderText="Choose a doctor"
                          HorizontalAlignment="Stretch"
                          ItemsSource="{Binding Doctors}"
                          DisplayMemberPath="DoctorName"
                          SelectedValuePath="DoctorId"/>

                <CalendarDatePicker x:Name="AppointmentDatePicker"
                                    Header="Date"
                                    HorizontalAlignment="Stretch"/>

                <TimePicker x:Name="AppointmentTimePicker"
                            Header="Start time"
                            HorizontalAlignment="Stretch"/>

                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0">
                    <Button Content="Create"
                            Click="CreateAppointment_Click"
                            Background="#0288D1"
                            MinWidth="120"/>

                    <Button Content="Cancel"
                            Click="Cancel_Click"
                            Background="#64748B"
                            MinWidth="120"/>
                </StackPanel>

                <InfoBar x:Name="StatusInfoBar" IsOpen="False" IsClosable="True" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>

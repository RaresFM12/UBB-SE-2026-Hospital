<Page
    x:Class="UBB_SE_2026_923_2.Views.Admin.ERDispatchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer Background="{StaticResource AppBackgroundBrush}">
        <Grid Padding="24" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Automated ER Dispatch &amp; Doctor Status Management"
                       Foreground="{StaticResource AppAccentBrush}"
                       FontSize="36"
                       FontWeight="SemiBold"/>

            <Grid Grid.Row="1" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Run Dispatch"
                        Click="RunDispatch_Click"/>

                <Button Grid.Column="1"
                        Content="Refresh"
                        Click="Refresh_Click"
                        Background="Transparent"
                        Foreground="{StaticResource AppAccentBrush}"
                        BorderBrush="{StaticResource AppAccentBrush}"
                        BorderThickness="1"/>

                <Button Grid.Column="2"
                        Content="Simulate Incoming"
                        Click="SimulateIncoming_Click"
                        Background="Transparent"
                        Foreground="{StaticResource AppAccentBrush}"
                        BorderBrush="{StaticResource AppAccentBrush}"
                        BorderThickness="1"/>

                <StackPanel Grid.Column="3" Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Dispatch Status:" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="16"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource AppTextPrimaryBrush}"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2"
                    Background="{StaticResource AppSurfaceBrush}"
                    BorderBrush="{StaticResource AppAccentBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12">
                <StackPanel Spacing="10">
                    <TextBlock Text="Click 'Run Dispatch' to process pending ER requests and automatically assign doctors."
                               Foreground="{StaticResource AppTextPrimaryBrush}"
                               TextWrapping="Wrap"/>

                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox Grid.Column="0"
                                  x:Name="UnmatchedRequestCombo"
                                  ItemsSource="{Binding UnmatchedRequests}"
                                  DisplayMemberPath="RequestLabel"
                                  SelectionChanged="UnmatchedRequestCombo_SelectionChanged"
                                  PlaceholderText="Select unmatched request"
                                  HorizontalAlignment="Stretch"/>

                        <ComboBox Grid.Column="1"
                                  x:Name="OverrideDoctorCombo"
                                  ItemsSource="{Binding OverrideCandidates}"
                                  DisplayMemberPath="DisplayLabel"
                                  PlaceholderText="Select IN_EXAMINATION doctor ending within 3 days"
                                  HorizontalAlignment="Stretch"/>

                        <Button Grid.Column="2"
                                Content="Apply Override"
                                Click="ApplyOverride_Click"/>
                    </Grid>

                    <TextBlock Text="{Binding ManualInterventionHint}"
                               Foreground="{StaticResource AppTextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="3"
                    Background="{StaticResource AppSurfaceBrush}"
                    BorderBrush="{StaticResource AppErrorBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="12"
                    Margin="0,10,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Unmatched Requests (Manual Intervention Required)"
                               Foreground="{StaticResource AppErrorBrush}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <ListView Grid.Row="1" ItemsSource="{Binding UnmatchedRequests}" Background="Transparent">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource AppErrorBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8" Background="{StaticResource AppBackgroundBrush}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding RequestSpecialization}" Foreground="{StaticResource AppTextPrimaryBrush}" FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding RequestLocation}" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding NoMatchReason}" Foreground="{StaticResource AppErrorBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Row="4"
                    Background="{StaticResource AppSurfaceBrush}"
                    BorderBrush="{StaticResource AppAccentBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="12"
                    Margin="0,10,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Successful Matches (Doctor Assigned)"
                               Foreground="{StaticResource AppAccentBrush}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <ListView Grid.Row="1" ItemsSource="{Binding SuccessfulMatches}" Background="Transparent">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource AppAccentBrush}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8" Background="{StaticResource AppBackgroundBrush}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding AssignedDoctor}" Foreground="{StaticResource AppTextPrimaryBrush}" FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Specialization}" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                                        <TextBlock Text="{Binding MatchReason}" Foreground="{StaticResource AppTextSecondaryBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>

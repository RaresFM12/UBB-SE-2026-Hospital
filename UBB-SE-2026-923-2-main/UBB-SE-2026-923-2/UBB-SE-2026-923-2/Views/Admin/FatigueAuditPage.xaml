<Page
    x:Class="UBB_SE_2026_923_2.Views.Admin.FatigueAuditPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:UBB_SE_2026_923_2.Converters">

    <Page.Resources>
        <converters:BoolToPublishStatusBrushConverter x:Key="PublishStatusBrushConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <ScrollViewer Background="{StaticResource AppBackgroundBrush}">
        <Grid Padding="24" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Staff Fatigue Audit &amp; Roster Validation"
                       Foreground="{StaticResource AppAccentBrush}"
                       FontSize="36"
                       FontWeight="SemiBold"/>

            <Grid Grid.Row="1" ColumnSpacing="10" Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="Week Starting:"
                           Foreground="{StaticResource AppTextPrimaryBrush}"
                           VerticalAlignment="Center"
                           FontSize="14"/>

                <CalendarDatePicker Grid.Column="1"
                                    x:Name="WeekStartPicker"
                                    DateChanged="WeekStartPicker_DateChanged"
                                    PlaceholderText="Select week"
                                    Margin="0"/>

                <Button Grid.Column="2"
                        Content="Run Auto-Audit"
                        Click="RunAutoAudit_Click"/>

                <Button Grid.Column="3"
                        Content="Refresh"
                        Click="Refresh_Click"
                        Background="Transparent"
                        Foreground="{StaticResource AppAccentBrush}"
                        BorderBrush="{StaticResource AppAccentBrush}"
                        BorderThickness="1"
                        Margin="8,0,0,0"/>

                <StackPanel Grid.Column="4" 
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <TextBlock Text="{Binding PublishStatus}"
                               Foreground="{Binding CanPublish, Converter={StaticResource PublishStatusBrushConverter}}"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2"
                    Background="{StaticResource AppSurfaceBrush}"
                    BorderBrush="{StaticResource AppAccentBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <StackPanel Spacing="6">
                    <TextBlock Text="Audit Status:"
                               Foreground="{StaticResource AppTextPrimaryBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource AppTextSecondaryBrush}"
                               TextWrapping="Wrap"
                               FontSize="12"/>
                    <TextBlock Text="{Binding WeekLabel}"
                               Foreground="{StaticResource AppTextSecondaryBrush}"
                               FontSize="11"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="3"
                    Background="{StaticResource AppSurfaceBrush}"
                    BorderBrush="{StaticResource AppErrorBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12"
                    Margin="0,8,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Fatigue Violations Detected"
                                   Foreground="{StaticResource AppErrorBrush}"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Rules: Max 60h/week, Min 12h rest between shifts"
                                   Foreground="{StaticResource AppTextSecondaryBrush}"
                                   FontSize="12"/>
                    </StackPanel>

                    <ListView Grid.Row="1" 
                              ItemsSource="{Binding Violations}"
                              Background="Transparent"
                              SelectionMode="None"
                              Margin="0,8,0,0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource AppErrorBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,8"
                                        Background="{StaticResource AppBackgroundBrush}">
                                    <Grid RowSpacing="6">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid ColumnSpacing="20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Staff:"
                                                           Foreground="{StaticResource AppTextSecondaryBrush}"
                                                           FontSize="11"/>
                                                <TextBlock Text="{Binding Staff}"
                                                           Foreground="{StaticResource AppTextPrimaryBrush}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Shift Window:"
                                                           Foreground="{StaticResource AppTextSecondaryBrush}"
                                                           FontSize="11"/>
                                                <TextBlock Text="{Binding Window}"
                                                           Foreground="{StaticResource AppTextPrimaryBrush}"
                                                           FontSize="12"
                                                           FontFamily="Courier New"/>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Grid.Row="1">
                                            <TextBlock Text="Rule Violated:"
                                                       Foreground="{StaticResource AppTextSecondaryBrush}"
                                                       FontSize="11"/>
                                            <TextBlock Text="{Binding Rule}"
                                                       Foreground="#D97706"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="2"
                                                   Text="{Binding Message}"
                                                   Foreground="{StaticResource AppErrorBrush}"
                                                   TextWrapping="Wrap"
                                                   FontSize="12"/>

                                        <TextBlock Grid.Row="3"
                                                   Text="⚠️ Roster cannot be published while violations exist"
                                                   Foreground="{StaticResource AppErrorBrush}"
                                                   FontSize="11"
                                                   FontStyle="Italic"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Row="4"
                    Background="{StaticResource AppSurfaceBrush}"
                    BorderBrush="{StaticResource AppAccentBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="12"
                    Margin="0,8,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Auto-Suggested Reassignments"
                                   Foreground="{StaticResource AppAccentBrush}"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="System recommends these changes to resolve violations"
                                   Foreground="{StaticResource AppTextSecondaryBrush}"
                                   FontSize="12"/>
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Margin="0,8,0,0"
                          RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Background="{StaticResource AppBackgroundBrush}"
                                BorderBrush="{StaticResource AppAccentBrush}"
                                BorderThickness="1"
                                Padding="10">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="130"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Shift ID"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1"
                                           Text="Current Staff"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="2"
                                           Text="Suggested Staff"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="3"
                                           Text="Reason"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="4"
                                           Text="Action"
                                           Foreground="{StaticResource AppTextSecondaryBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"/>
                            </Grid>
                        </Border>

                        <ListView Grid.Row="1"
                                  ItemsSource="{Binding Suggestions}"
                                  Background="Transparent"
                                  SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource AppAccentBrush}"
                                            BorderThickness="0,0,0,1"
                                            Padding="10"
                                            Background="{StaticResource AppBackgroundBrush}">
                                        <Grid ColumnSpacing="12"
                                              VerticalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="3*"/>
                                                <ColumnDefinition Width="130"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{Binding ShiftId}"
                                                       Foreground="{StaticResource AppTextPrimaryBrush}"
                                                       FontSize="13"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding OriginalStaffDisplay}"
                                                       Foreground="{StaticResource AppTextPrimaryBrush}"
                                                       FontSize="13"
                                                       TextWrapping="WrapWholeWords"/>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding SuggestedStaffDisplay}"
                                                       Foreground="{StaticResource AppTextPrimaryBrush}"
                                                       FontSize="13"
                                                       TextWrapping="WrapWholeWords"/>
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding Reason}"
                                                       Foreground="{StaticResource AppTextSecondaryBrush}"
                                                       FontSize="12"
                                                       TextWrapping="WrapWholeWords"/>

                                            <Button Grid.Column="4"
                                                    Content="Reassign"
                                                    Click="ApplyReassignment_Click"
                                                    Tag="{Binding}"
                                                    Visibility="{Binding HasSuggestedStaff, Converter={StaticResource BoolToVisibilityConverter}}"
                                                    HorizontalAlignment="Left"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="5"
                    Background="{StaticResource AppSurfaceBrush}"
                    BorderBrush="{StaticResource AppAccentBrush}"
                    BorderThickness="2"
                    CornerRadius="12"
                    Padding="16"
                    Margin="0,8,0,0">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Roster Publication"
                                   Foreground="{StaticResource AppAccentBrush}"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding PublishStatus}"
                                   Foreground="{Binding CanPublish, Converter={StaticResource PublishStatusBrushConverter}}"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <TextBlock Text="{Binding PublishStatusDescription}"
                               Foreground="{StaticResource AppTextSecondaryBrush}"
                               TextWrapping="Wrap"
                               FontSize="12"/>

                    <Button Content="Publish Roster"
                            Click="PublishRoster_Click"
                            IsEnabled="{Binding CanPublish}"
                            Width="200"
                            HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>

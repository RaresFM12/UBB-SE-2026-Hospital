<Page
    x:Class="UBB_SE_2026_923_2.Views.Doctor.DoctorSchedulePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:UBB_SE_2026_923_2.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVisibilityConverter"/>
    </Page.Resources>

    <Grid Padding="24" RowSpacing="14" Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Doctor Schedule"
                       Foreground="{StaticResource AppTextPrimaryBrush}"
                       FontSize="44"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

            <ComboBox Grid.Column="1"
                      Height="40"
                      ItemsSource="{Binding Doctors}"
                      SelectedItem="{Binding SelectedDoctor, Mode=TwoWay}"
                      DisplayMemberPath="DoctorName"
                      PlaceholderText="Select doctor"
                      HorizontalAlignment="Stretch"/>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Content="{Binding PreviousButtonText}"
                    Command="{Binding PreviousDayCommand}"/>

            <Button Grid.Column="1"
                    Content="Today"
                    Command="{Binding TodayCommand}"/>

            <Button Grid.Column="2"
                    Content="{Binding NextButtonText}"
                    Command="{Binding NextDayCommand}"/>

            <Button x:Name="DateButton"
                    Grid.Column="3"
                    Content="{Binding SelectedDateText}"
                    Margin="8,0,0,0"
                    Background="Transparent"
                    Foreground="{StaticResource AppAccentBrush}"
                    BorderBrush="{StaticResource AppAccentBrush}"
                    BorderThickness="1"
                    Padding="12,6">
                <Button.Flyout>
                    <Flyout Placement="Bottom">
                        <CalendarView x:Name="DateCalendar"
                                      SelectionMode="Single"
                                      SelectedDatesChanged="DateCalendar_SelectedDatesChanged"/>
                    </Flyout>
                </Button.Flyout>
            </Button>

            <Button Grid.Column="4"
                    Content="Daily"
                    Command="{Binding DailyModeCommand}"
                    Margin="8,0,0,0"/>

            <Button Grid.Column="5"
                    Content="Weekly"
                    Command="{Binding WeeklyModeCommand}"/>

            <Button Grid.Column="6"
                    Content="Refresh"
                    Command="{Binding RefreshCommand}"/>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppErrorBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="14,10"
                Visibility="{Binding ErrorMessage, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource AppErrorBrush}"
                       TextWrapping="Wrap"/>
        </Border>

        <Grid Grid.Row="3">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Text="No appointments or shifts for this period."
                           Foreground="{StaticResource AppTextPrimaryBrush}"
                           FontSize="20"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Try Previous/Next, click date, or Refresh."
                           Foreground="{StaticResource AppTextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="16">
                    <TextBlock Text="Appointments"
                               Foreground="{StaticResource AppAccentBrush}"
                               FontSize="20"
                               FontWeight="SemiBold"/>

                    <ItemsControl ItemsSource="{Binding Appointments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource AppSurfaceBrush}"
                                        BorderBrush="{StaticResource AppAccentBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="12"
                                        Margin="0,0,0,12">
                                    <Grid ColumnSpacing="14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding DateText}"
                                                       Foreground="{StaticResource AppTextSecondaryBrush}"
                                                       FontSize="28"/>
                                            <TextBlock Text="{Binding TimeRangeText}"
                                                       Foreground="{StaticResource AppTextPrimaryBrush}"
                                                       FontSize="24"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Status}"
                                                       Foreground="{StaticResource AppTextSecondaryBrush}"
                                                       FontSize="20"/>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Content="Details"
                                                Click="DetailsButton_Click"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Shifts"
                               Foreground="{StaticResource AppAccentBrush}"
                               FontSize="20"
                               FontWeight="SemiBold"/>

                    <ItemsControl ItemsSource="{Binding Shifts}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource AppSurfaceBrush}"
                                        BorderBrush="{StaticResource AppAccentBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="12"
                                        Margin="0,0,0,12">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding DateText}"
                                                   Foreground="{StaticResource AppTextSecondaryBrush}"
                                                   FontSize="28"/>
                                        <TextBlock Text="{Binding TimeRangeText}"
                                                   Foreground="{StaticResource AppTextPrimaryBrush}"
                                                   FontSize="24"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding LocationText}"
                                                   Foreground="{StaticResource AppTextSecondaryBrush}"
                                                   FontSize="20"/>
                                        <TextBlock Text="{Binding Status}"
                                                   Foreground="{StaticResource AppTextSecondaryBrush}"
                                                   FontSize="18"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
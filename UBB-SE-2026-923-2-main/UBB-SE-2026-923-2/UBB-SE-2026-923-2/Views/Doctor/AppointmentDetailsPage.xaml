<Page
    x:Class="UBB_SE_2026_923_2.Views.Doctor.AppointmentDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{StaticResource AppBackgroundBrush}" Padding="40">
        <Border Background="{StaticResource AppSurfaceBrush}" 
                BorderBrush="{StaticResource AppAccentBrush}" 
                BorderThickness="1" 
                CornerRadius="12" 
                Padding="30" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                Width="450">
            <StackPanel Spacing="20">
                <TextBlock Text="Appointment Details" 
                           Foreground="{StaticResource AppAccentBrush}" 
                           FontSize="28" 
                           FontWeight="SemiBold" 
                           Margin="0,0,0,10"/>

                <StackPanel Spacing="5">
                    <TextBlock Text="Patient:" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="12"/>
                    <TextBlock x:Name="PatientNameText" Foreground="{StaticResource AppTextPrimaryBrush}" FontSize="18" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="Doctor:" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="12"/>
                    <TextBlock x:Name="DoctorNameText" Foreground="{StaticResource AppTextPrimaryBrush}" FontSize="18"/>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="5">
                        <TextBlock Text="Date:" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="12"/>
                        <TextBlock x:Name="DateText" Foreground="{StaticResource AppTextPrimaryBrush}" FontSize="16"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="5">
                        <TextBlock Text="Time:" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="12"/>
                        <TextBlock x:Name="TimeText" Foreground="{StaticResource AppTextPrimaryBrush}" FontSize="16"/>
                    </StackPanel>
                </Grid>

                <StackPanel Spacing="5" Margin="0,10,0,20">
                    <TextBlock Text="Current Status:" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="12"/>
                    <TextBlock x:Name="StatusText" Foreground="{StaticResource AppAccentBrush}" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>

                <Button Content="Mark as Finished" 
                        Click="FinishBtn_Click" 
                        HorizontalAlignment="Stretch"/>

                <Button Content="Go Back" 
                        Click="GoBack_Click" 
                        Background="Transparent" 
                        BorderBrush="{StaticResource AppAccentBrush}" 
                        BorderThickness="1" 
                        Foreground="{StaticResource AppAccentBrush}" 
                        HorizontalAlignment="Stretch" 
                        Margin="0,10,0,0"/>

                <InfoBar x:Name="StatusInfoBar" IsOpen="False" IsClosable="True" Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
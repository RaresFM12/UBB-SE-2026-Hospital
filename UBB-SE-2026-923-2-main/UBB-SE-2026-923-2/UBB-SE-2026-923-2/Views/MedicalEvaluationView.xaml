<Page
    x:Class="UBB_SE_2026_923_2.Views.MedicalEvaluationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:UBB_SE_2026_923_2.Models"
    xmlns:converters="using:UBB_SE_2026_923_2.Converters" 
    mc:Ignorable="d"
    Background="{StaticResource AppBackgroundBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="15" Margin="0,0,0,20">
            <SymbolIcon Symbol="Contact" Foreground="{StaticResource AppAccentBrush}" VerticalAlignment="Center"/>
            <TextBlock Text="Current Staff:" VerticalAlignment="Center" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="14"/>

            <ComboBox ItemsSource="{x:Bind ViewModel.AllDoctors, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedDoctor, Mode=TwoWay}"
                      BorderThickness="0"
                      Background="Transparent"
                      VerticalAlignment="Center">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="models:Doctor">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="Dr." FontWeight="Bold" Foreground="{StaticResource AppAccentBrush}"/>
                            <TextBlock Text="{x:Bind FirstName}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                            <TextBlock Text="{x:Bind LastName}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                            <TextBlock Text=" - ID:" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="10" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind StaffID}" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="10" VerticalAlignment="Center"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="450"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,30,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="15" Padding="0,0,15,20">
                        <TextBlock Text="1. MEDICAL EVALUATIONS" FontSize="24" FontWeight="Bold" Margin="0,0,0,10" Foreground="{StaticResource AppAccentBrush}"/>

                        <StackPanel Spacing="5">
                            <TextBlock Text="Select Patient from Schedule" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource AppTextSecondaryBrush}"/>
                            <ComboBox HorizontalAlignment="Stretch"
                                      PlaceholderText="Choose a patient..."
                                      ItemsSource="{x:Bind ViewModel.AvailableAppointments, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedAppointment, Mode=TwoWay}"
                                      IsEnabled="{x:Bind ViewModel.IsFormEnabled, Mode=OneWay}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:Appointment">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind StartTime}" Foreground="{StaticResource AppAccentBrush}" FontWeight="Bold"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5">
                                                <TextBlock Text="{x:Bind PatientName}" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                                                <TextBlock Text="{x:Bind Notes}" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <TextBox Header="Active Patient ID" 
                                 Text="{x:Bind ViewModel.PatientId, Mode=OneWay}" 
                                 IsReadOnly="True" 
                                 Background="Transparent"/>

                        <TextBox Header="Symptoms" 
                                 Text="{x:Bind ViewModel.Symptoms, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                 IsEnabled="{x:Bind ViewModel.IsFormEnabled, Mode=OneWay}"
                                 PlaceholderText="Enter symptoms..." 
                                 AcceptsReturn="True" MinHeight="100"
                                 MaxLength="500"/>

                        <TextBox Header="Meds List" 
                                 Text="{x:Bind ViewModel.MedicationsList, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Enter medications..." AcceptsReturn="True" MinHeight="60"
                                 IsEnabled="{x:Bind ViewModel.IsFormEnabled, Mode=OneWay}"
                                 MaxLength="200"/>

                        <StackPanel Visibility="{x:Bind ViewModel.ConflictVisibility, Mode=OneWay}" Spacing="10">
                            <InfoBar Severity="Error" Title="Risk Conflict Detected"
                                     Message="{x:Bind ViewModel.ConflictWarning, Mode=OneWay}"
                                     IsOpen="True" IsClosable="False" />
                            <CheckBox Content="I assume clinical risk for this prescription" 
                                      IsChecked="{x:Bind ViewModel.IsRiskAssumed, Mode=TwoWay}"
                                      IsEnabled="{x:Bind ViewModel.IsFormEnabled, Mode=OneWay}"
                                      FontWeight="Bold" Foreground="{StaticResource AppErrorBrush}"/>
                        </StackPanel>

                        <TextBox Header="Doctor Notes" 
                                 Text="{x:Bind ViewModel.DoctorNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Write justification here..." 
                                 AcceptsReturn="True" MinHeight="100"
                                 IsEnabled="{x:Bind ViewModel.IsFormEnabled, Mode=OneWay}"
                                 MaxLength="1000"/>

                        <TextBlock Text="{x:Bind ViewModel.ValidationError, Mode=OneWay}" 
                                   Foreground="{StaticResource AppErrorBrush}" FontSize="13" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" TextWrapping="WrapWholeWords" Margin="0,5"/>

                        <Button Content="Save Diagnosis" 
                                Command="{x:Bind ViewModel.SaveDiagnosisCommand}" 
                                HorizontalAlignment="Stretch" Height="45"/>

                        <Button Content="Delete Diagnosis" 
                                IsEnabled="{x:Bind ViewModel.IsEditing, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.IsEditing, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                HorizontalAlignment="Stretch" Height="45"
                                Background="{StaticResource AppErrorBrush}" Foreground="White"
                                Command="{x:Bind ViewModel.DeleteEvaluationCommand}"/>

                        <Button Content="Cancel Selection" 
                                Visibility="{x:Bind ViewModel.IsEditing, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                                Click="{x:Bind ViewModel.ResetForm}"
                                Background="Transparent" Foreground="{StaticResource AppAccentBrush}" BorderBrush="{StaticResource AppAccentBrush}" BorderThickness="1"
                                HorizontalAlignment="Stretch" Margin="0,5"/>
                    </StackPanel>
                </ScrollViewer>

                <Grid Visibility="{x:Bind ViewModel.LockoutVisibility, Mode=OneWay}" 
                      Background="#CCFFFFFF" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Canvas.ZIndex="10">
                    <Border Background="{StaticResource AppErrorBrush}" VerticalAlignment="Center" Padding="20,40" CornerRadius="8" Margin="10">
                        <StackPanel Spacing="5" HorizontalAlignment="Center">
                            <TextBlock Text="CLINICAL LOCKOUT." FontSize="32" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Maximum duty hours (12h) exceeded." FontSize="20" Foreground="White" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <StackPanel Grid.Column="1" Spacing="10">
                <TextBlock Text="Medical Records" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AppAccentBrush}"/>

                <TextBox PlaceholderText="Search by Patient ID..."
                         Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Header="Filter History"
                         Margin="0,0,0,10"/>

                <Grid VerticalAlignment="Stretch">
                    <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                                  Width="60" Height="60"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Canvas.ZIndex="2"/>

                    <StackPanel Visibility="{x:Bind ViewModel.EmptyStateVisibility, Mode=OneWay}"
                                VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12" Margin="0,100,0,0">
                        <FontIcon Glyph="&#xE8A5;" FontSize="56" Foreground="{StaticResource AppTextSecondaryBrush}" Opacity="0.4"/>
                        <TextBlock Text="No records found." FontSize="16" Foreground="{StaticResource AppTextSecondaryBrush}" FontStyle="Italic"/>
                    </StackPanel>

                    <ListView ItemsSource="{x:Bind ViewModel.PastEvaluations, Mode=OneWay}" 
                              SelectedItem="{x:Bind ViewModel.SelectedEvaluation, Mode=TwoWay}"
                              Background="{StaticResource AppSurfaceBrush}" 
                              CornerRadius="8" Padding="10" MinHeight="400">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:MedicalEvaluation">
                                <Grid Padding="10" BorderBrush="{StaticResource AppAccentBrush}" BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                        <TextBlock Text="{x:Bind FormattedDate}" FontWeight="Bold" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                                        <TextBlock Text="{x:Bind FormattedTime}" Foreground="{StaticResource AppTextSecondaryBrush}" FontSize="12"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{x:Bind Symptoms}" TextTrimming="CharacterEllipsis" MaxLines="1" Foreground="{StaticResource AppTextPrimaryBrush}"/>
                                        <TextBlock Text="Status: Completed" FontSize="11" Foreground="{StaticResource AppAccentBrush}" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Page>

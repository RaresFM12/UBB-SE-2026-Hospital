@model HospitalManagement.Web.Models.Transplant.OrganDonorViewModel

@{
    ViewData["Title"] = "Organ Donor Assignment";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Organ Donor Assignment</h1>
        <p class="text-muted mb-0">Donor: <strong>@Model.PatientName</strong></p>
    </div>
    <a asp-action="Index" asp-controller="Admin"
       asp-route-selectedId="@Model.PatientId"
       class="btn btn-outline-secondary">Back to Patient</a>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
}

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-info" role="alert">@Model.StatusMessage</div>
}

<div class="card mb-4">
    <div class="card-body">
        <form method="get" asp-action="Assign" class="row g-3 align-items-end">
            <input type="hidden" name="patientId" value="@Model.PatientId" />
            <div class="col-auto">
                <label for="organ" class="form-label fw-semibold">Select Organ</label>
                <select id="organ" name="organ" class="form-select" onchange="this.form.submit()">
                    <option value="">Choose an organ...</option>
                    @foreach (var o in Model.Organs)
                    {
                        <option value="@o" selected="@(Model.SelectedOrgan == o ? "selected" : null)">@o</option>
                    }
                </select>
            </div>
        </form>
    </div>
</div>

@if (Model.TopMatches.Count > 0)
{
    <h5 class="mb-3">Top 5 Compatible Recipients</h5>

    <form method="post" asp-action="Confirm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="patientId" value="@Model.PatientId" />

        <div class="table-responsive mb-3">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th></th>
                        <th>Recipient</th>
                        <th>Blood Type</th>
                        <th>Score %</th>
                        <th>Waiting Days</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var match in Model.TopMatches)
                    {
                        <tr>
                            <td>
                                <input type="radio" name="transplantId" value="@match.TransplantId"
                                       class="form-check-input"
                                       data-score="@match.CompatibilityScore"
                                       onchange="document.getElementById('compatibilityScore').value = this.dataset.score" />
                            </td>
                            <td>@match.ReceiverName</td>
                            <td>@match.BloodType</td>
                            <td><span class="fw-semibold text-success">@match.CompatibilityScore</span></td>
                            <td>@match.WaitingDays</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <input type="hidden" id="compatibilityScore" name="compatibilityScore" value="0" />

        <button type="submit" class="btn btn-primary">Confirm Assignment</button>
    </form>
}
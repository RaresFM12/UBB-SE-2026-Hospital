@model HospitalManagement.Web.Models.Pharmacist.PoliceAlertViewModel

@{
    ViewData["Title"] = "Police Report";
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Police Report</h1>
        <p class="text-muted mb-0">Generated report for law enforcement.</p>
    </div>
    <a asp-action="Addicts" class="btn btn-outline-secondary">Back to Candidates</a>
</div>

<div class="card border-danger">
    <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
        <strong>Police Alert</strong>
        @if (Model.AlreadySent)
        {
            <span class="badge bg-light text-danger fs-6">Sent</span>
        }
        else
        {
            <button id="sendPoliceBtn" type="button" class="btn btn-light btn-sm text-danger fw-bold">
                Send to Police
            </button>
        }
    </div>
    <div class="card-body">
        <pre class="mb-0" style="white-space: pre-wrap; word-break: break-word;">@Model.ReportText</pre>
    </div>
</div>

@if (Model.AlreadySent)
{
    <div class="alert alert-success mt-3">
        Report successfully sent to law enforcement.
    </div>
}

@if (!Model.AlreadySent)
{
    <form id="confirmForm" asp-action="ConfirmPoliceReport" method="post" style="display:none">
        @Html.AntiForgeryToken()
        <input type="hidden" name="patientId" value="@Model.PatientId" />
        <input type="hidden" name="reportText" value="@Model.ReportText" />
    </form>
}

@section Scripts {
    @if (!Model.AlreadySent)
    {
        <script>
            (() => {
                // Two-tone alternating police siren built with Web Audio API.
                // Plays for ~2.4s, then submits the confirm form.
                function playPoliceSiren() {
                    try {
                        const ctx = new (window.AudioContext || window.webkitAudioContext)();
                        const osc = ctx.createOscillator();
                        const gain = ctx.createGain();
                        osc.type = 'sawtooth';
                        osc.connect(gain);
                        gain.connect(ctx.destination);
                        gain.gain.setValueAtTime(0.18, ctx.currentTime);

                        // Alternate between two pitches (~750Hz and ~1100Hz)
                        // every 0.4s, four cycles total => 2.4s of siren.
                        const lowHz = 750;
                        const highHz = 1100;
                        const stepDuration = 0.4;
                        const cycles = 3;
                        const now = ctx.currentTime;
                        osc.frequency.setValueAtTime(lowHz, now);
                        for (let i = 0; i < cycles; i++) {
                            const base = now + i * stepDuration * 2;
                            osc.frequency.setValueAtTime(highHz, base);
                            osc.frequency.setValueAtTime(lowHz, base + stepDuration);
                        }
                        const totalDuration = cycles * stepDuration * 2;
                        // Fade out at the end so it doesn't click.
                        gain.gain.setValueAtTime(0.18, now + totalDuration - 0.05);
                        gain.gain.exponentialRampToValueAtTime(0.001, now + totalDuration);
                        osc.start(now);
                        osc.stop(now + totalDuration);
                    } catch (_) { /* audio not allowed yet, ignore */ }
                }

                document.getElementById('sendPoliceBtn').addEventListener('click', () => {
                    playPoliceSiren();
                    // Wait long enough that the user actually hears the siren
                    // before the page navigates away.
                    setTimeout(() => document.getElementById('confirmForm').submit(), 2500);
                });
            })();
        </script>
    }
}

@model HospitalManagement.Web.Models.Pharmacist.AddictListViewModel

@{
    ViewData["Title"] = "Addict Candidates";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-1">Addict Candidates</h1>
        <p class="text-muted mb-0">Patients flagged for potential substance dependency.</p>
    </div>
    <a asp-controller="Prescription" asp-action="Feed" class="btn btn-outline-secondary">Back to Prescriptions</a>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success" role="alert">@successMessage</div>
}
@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (Model.Candidates.Count == 0)
{
    <div class="alert alert-info" role="alert">No addict candidates found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var candidate in Model.Candidates)
                {
                    <tr>
                        <td>@candidate.Id</td>
                        <td>@candidate.FullName</td>
                        <td>
                            <form asp-action="BuildPoliceReport" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="patientId" value="@candidate.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Build Police Report</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

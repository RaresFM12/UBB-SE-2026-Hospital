@model List<HospitalManagement.Web.Models.Statistics.StatisticDataPointViewModel>

@if (Model.Count == 0)
{
    <p class="text-muted">No data available.</p>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var point in Model)
        {
            <div>
                <div class="d-flex justify-content-between mb-1">
                    <span>@point.Label</span>
                    <strong>@point.Value</strong>
                </div>
                <div class="progress" role="progressbar" aria-valuenow="@point.Value" aria-valuemin="0">
                    <div class="progress-bar" style="width: @point.WidthPercent%;"></div>
                </div>
            </div>
        }
    </div>
}

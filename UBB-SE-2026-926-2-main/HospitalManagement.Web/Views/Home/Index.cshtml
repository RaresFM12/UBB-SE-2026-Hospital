@{
    ViewData["Title"] = "Home Page";
}

<div class="py-5 text-center">
    <h1 class="display-5 fw-semibold">Hospital Management MVC</h1>
    @if (TempData["LoginMessage"] is string loginMessage)
    {
        <div class="alert alert-success mt-3" role="alert">@loginMessage</div>
    }
    <p class="lead text-muted">Your web GUI now includes an admin patient dashboard that mirrors the original desktop interaction more closely.</p>
    <a asp-controller="Admin" asp-action="Index" class="btn btn-primary btn-lg">Open admin dashboard</a>
</div>

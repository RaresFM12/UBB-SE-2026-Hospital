<Page
    x:Class="HospitalManagement.View.MedicalStaffDashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:entity="using:Common.Data.Entity"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Grid Padding="24" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12" Margin="0,0,0,24">
            <TextBox x:Name="SearchTextBox" PlaceholderText="Search patients by name or CNP..." Width="400" Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button Content="Go" Command="{x:Bind ViewModel.SearchCommand}" Style="{StaticResource AccentButtonStyle}" Width="80"/>
        </StackPanel>

        <Grid Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" Foreground="#D13438" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,16" />

            <ListView Grid.Row="1" Grid.Column="0" ItemsSource="{x:Bind ViewModel.SearchResults, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedPatient, Mode=TwoWay}" DoubleTapped="PatientList_DoubleTapped" SelectionMode="Single">
                <ListView.Header>
                    <Grid Padding="12,8" Background="{ThemeResource LayerFillColorAltBrush}" CornerRadius="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="First Name" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="Last Name" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Grid.Column="2" Text="CNP" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Grid.Column="3" Text="Date of Birth" FontWeight="Bold" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                </ListView.Header>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="entity:Patient">
                        <Grid Padding="12,12" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind FirstName}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{x:Bind LastName}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{x:Bind Cnp}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{x:Bind Dob.ToString()}" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel Grid.Row="1" Grid.Column="1" Margin="20,0,0,0" Width="240" Spacing="15" VerticalAlignment="Top" Visibility="{x:Bind ViewModel.SelectedPatientVisibility, Mode=OneWay}">
                <TextBlock Text="Patient Actions" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,10"/>
                <Button Content="Compatible Blood Donors" Command="{x:Bind ViewModel.FindBloodDonorsCommand}" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}"/>
                <Button Content="Request Organ Transplant" Command="{x:Bind ViewModel.RequestTransplantCommand}" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left" Spacing="12" Margin="0,24,0,0">
            <Button Content="I saw a ghost" Command="{x:Bind ViewModel.GhostSightingCommand}" Background="DarkRed" Foreground="White"/>
        </StackPanel>

        <Grid Grid.RowSpan="3" Background="#F0000000" IsHitTestVisible="True" Visibility="{x:Bind ViewModel.ExorcismAlertVisibility, Mode=OneWay}">
            <Border MaxWidth="600" CornerRadius="16" Background="#1A0000" BorderBrush="#CC0000" BorderThickness="3" Padding="48,40" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Spacing="20" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE7BA;" FontSize="72" Foreground="#CC0000" HorizontalAlignment="Center"/>
                    <TextBlock Text="CRITICAL PARANORMAL ACTIVITY DETECTED" Foreground="#FF3333" FontSize="20" FontWeight="Bold" TextAlignment="Center" TextWrapping="Wrap"/>
                    <TextBlock Text="Multiple sightings confirmed. Please CALL THE PRIEST immediately." Foreground="White" FontSize="16" TextAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>

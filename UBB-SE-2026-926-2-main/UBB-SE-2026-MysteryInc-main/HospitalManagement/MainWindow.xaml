<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="HospitalManagement.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Unified Hospital Management">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <!-- Login frame — visible on startup, hidden after authentication -->
        <Frame x:Name="LoginFrame" />

        <!-- Main app shell — hidden until the user logs in -->
        <NavigationView x:Name="AppNavigationView"
                        IsBackButtonVisible="Collapsed"
                        PaneDisplayMode="Left"
                        Visibility="Collapsed"
                        IsEnabled="False"
                        SelectionChanged="AppNavigationView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Admin Dashboard" Tag="AdminDashboard" />
                <NavigationViewItem Content="Medical Staff" Tag="MedicalStaffDashboard" />
                <NavigationViewItem Content="Pharmacy" Tag="PharmacistDashboard" />
                <NavigationViewItemSeparator />
                <NavigationViewItem Content="Patient Registration" Tag="PatientRegistration" />
                <NavigationViewItem Content="Queue" Tag="Queue" />
                <NavigationViewItem Content="Triage" Tag="Triage" />
                <NavigationViewItem Content="Room Assignment" Tag="RoomAssignment" />
                <NavigationViewItem Content="Examination" Tag="Examination" />
                <NavigationViewItem Content="Transfer Log" Tag="TransferLog" />
                <NavigationViewItem Content="Room Management" Tag="RoomManagement" />
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>

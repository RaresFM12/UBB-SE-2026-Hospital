<UserControl
    x:Class="ERManagementSystem.Views.VisitDetailsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="16">

            <!-- Title -->
            <TextBlock Text="Visit Details"
                       Style="{StaticResource PageTitleTextBlockStyle}"/>

            <!-- Patient Info Card -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Patient Information"
                               Style="{StaticResource SectionTitleTextBlockStyle}"/>
                    <Grid ColumnDefinitions="*,*"
                          RowDefinitions="Auto,Auto,Auto"
                          ColumnSpacing="8" RowSpacing="6">

                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                            <TextBlock Text="Full Name:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="FullNameText" TextWrapping="WrapWholeWords"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                            <TextBlock Text="CNP:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="PatientIdText" TextWrapping="WrapWholeWords"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2">
                            <TextBlock Text="Date of Birth:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="DateOfBirthText"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                            <TextBlock Text="Gender:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="GenderText"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0" Spacing="2">
                            <TextBlock Text="Phone:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="PhoneText" TextWrapping="WrapWholeWords"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Spacing="2">
                            <TextBlock Text="Emergency:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="EmergencyContactText" TextWrapping="WrapWholeWords"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Visit Info Card -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Visit Information"
                               Style="{StaticResource SectionTitleTextBlockStyle}"/>
                    <Grid ColumnDefinitions="*,*"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="8" RowSpacing="6">

                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                            <TextBlock Text="Visit ID:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="VisitIdText"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                            <TextBlock Text="Arrival:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="ArrivalText"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="2">
                            <TextBlock Text="Chief Complaint:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="ChiefComplaintText" TextWrapping="WrapWholeWords"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Triage Info Card — hidden until triage exists -->
            <Border Style="{StaticResource CardBorderStyle}"
                    x:Name="TriageCard"
                    Visibility="Collapsed">
                <StackPanel Spacing="8">
                    <TextBlock Text="Triage Information"
                               Style="{StaticResource SectionTitleTextBlockStyle}"/>
                    <Grid ColumnDefinitions="*,*"
                          RowDefinitions="Auto,Auto"
                          ColumnSpacing="8" RowSpacing="6">

                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                            <TextBlock Text="Triage Level:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TriageLevelText"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                            <TextBlock Text="Specialization:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="SpecializationText" TextWrapping="WrapWholeWords"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2">
                            <TextBlock Text="Nurse ID:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="NurseIdText"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                            <TextBlock Text="Triage Time:" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TriageTimeText"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- State History Timeline -->
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Visit Status Timeline"
                               Style="{StaticResource SectionTitleTextBlockStyle}"/>
                    <ItemsControl x:Name="TimelineItems">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4">
                                    <Ellipse Width="12" Height="12"
                                             VerticalAlignment="Center"
                                             Fill="{Binding DotColor}"/>
                                    <TextBlock Text="{Binding Label}"
                                               FontWeight="{Binding Weight}"
                                               Foreground="{Binding TextColor}"
                                               VerticalAlignment="Center"/>
                                    <Border Background="{StaticResource PrimaryBrush}"
                                            CornerRadius="4" Padding="6,2"
                                            Visibility="{Binding BadgeVisibility}">
                                        <TextBlock Text="← Current"
                                                   Foreground="White"
                                                   FontSize="11"/>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
